---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  schema?: object | object[];
}

const {
  title = 'Damien Herlihy — A Digital Universe',
  description = 'Damien Herlihy is both a teacher and a learner of languages. Teacher, PKM nerd, and video maker — constructing a digital universe of notes, essays, and ideas.',
  image = '/images/og-default.jpg',
  schema,
} = Astro.props;

const SITE = Astro.site ?? new URL('https://www.damienherlihy.com');
const canonicalURL = new URL(Astro.url.pathname, SITE);

// Site-wide identity graph — Damien (Person) + the site (WebSite), linked by @id so AI
// engines treat every page as authored by the same verifiable person.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': new URL('/#damien', SITE).href,
  name: 'Damien Herlihy',
  url: SITE.href,
  image: new URL('/images/about/authentic.jpeg', SITE).href,
  jobTitle: 'Language teacher, writer, and co-founder of TEC',
  description:
    'Australian teacher and learner of languages — TESOL-trained, former IELTS examiner and EAP teacher, now building a digital universe of notes, essays and ideas.',
  nationality: 'Australian',
  homeLocation: { '@type': 'Place', name: 'Brisbane, Australia' },
  knowsAbout: [
    'English language teaching',
    'TESOL',
    'Second language acquisition',
    'Personal knowledge management',
    'AI and teaching',
    'Language learning',
    'Digital gardens',
  ],
  worksFor: [
    { '@type': 'Organization', name: 'TEC — Trat English Community', url: 'https://www.tecschool.org/' },
    { '@type': 'Organization', name: 'Language Layouts', url: 'https://www.languagelayouts.com/' },
  ],
  sameAs: [
    'https://www.youtube.com/@damienherlihy',
    'https://www.languagelayouts.com/',
    'https://dis-aster.vercel.app',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': new URL('/#website', SITE).href,
  name: 'Damien Herlihy — A Digital Universe',
  url: SITE.href,
  description,
  inLanguage: 'en',
  author: { '@id': new URL('/#damien', SITE).href },
  publisher: { '@id': new URL('/#damien', SITE).href },
};

const allPosts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((p) => ({
    title: p.data.title,
    description: p.data.description || '',
    category: p.data.category,
    tag: p.data.tag,
    slug: p.id,
  }));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08080d" />
    <meta name="color-scheme" content="dark" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonicalURL).href} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, canonicalURL).href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..600&family=Outfit:wght@300..700&family=Space+Mono:ital,wght@0,400;0,700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
    <script is:inline>
      document.documentElement.classList.add('js');
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
    </script>
  </head>
  <body>
    <div class="sky" aria-hidden="true"></div>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header posts={allPosts} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <div class="noise" aria-hidden="true"></div>

    <script>
      import Lenis from 'lenis';
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const finePointer = window.matchMedia('(pointer: fine)').matches;

      /* ---- Smooth scrolling with inertia (Lenis + GSAP ticker) ---- */
      if (!reducedMotion) {
        const lenis = new Lenis({
          duration: 1.15,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        });
        (window as any).__lenis = lenis;
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time) => lenis.raf(time * 1000));
        gsap.ticker.lagSmoothing(0);

        // In-page anchors travel through Lenis
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const id = a.getAttribute('href');
            if (!id || id === '#') return;
            const target = document.querySelector(id);
            if (!target) return;
            e.preventDefault();
            lenis.scrollTo(target as HTMLElement, { offset: -70 });
          });
        });
      }

      /* ---- Scroll reveals ---- */
      if (!reducedMotion) {
        gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
          const delay = parseFloat(el.dataset.revealDelay || '0');
          gsap.to(el, {
            opacity: 1,
            y: 0,
            duration: 1.1,
            delay,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 88%',
              once: true,
            },
            onComplete: () => {
              el.classList.add('is-revealed');
              gsap.set(el, { clearProps: 'transform,opacity' });
            },
          });
        });
      } else {
        document
          .querySelectorAll<HTMLElement>('[data-reveal]')
          .forEach((el) => ((el.style.opacity = '1'), (el.style.transform = 'none')));
      }

      /* ---- Magnetic pull on buttons ---- */
      if (!reducedMotion && finePointer) {
        document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach((el) => {
          const xTo = gsap.quickTo(el, 'x', { duration: 0.5, ease: 'power3.out' });
          const yTo = gsap.quickTo(el, 'y', { duration: 0.5, ease: 'power3.out' });
          el.addEventListener('pointermove', (e) => {
            const r = el.getBoundingClientRect();
            xTo((e.clientX - (r.left + r.width / 2)) * 0.28);
            yTo((e.clientY - (r.top + r.height / 2)) * 0.28);
          });
          el.addEventListener('pointerleave', () => {
            gsap.to(el, { x: 0, y: 0, duration: 0.9, ease: 'elastic.out(1, 0.4)' });
          });
        });
      }

      /* ---- Spotlight borders follow the cursor ---- */
      if (finePointer) {
        document.addEventListener('pointermove', (e) => {
          const card = (e.target as HTMLElement).closest?.('.spotlight-card') as HTMLElement | null;
          if (!card) return;
          const r = card.getBoundingClientRect();
          card.style.setProperty('--mx', `${e.clientX - r.left}px`);
          card.style.setProperty('--my', `${e.clientY - r.top}px`);
        });
      }

      /* ---- Inline sound-effect play buttons ---- */
      {
        let current: HTMLAudioElement | null = null;
        let currentBtn: HTMLButtonElement | null = null;
        const reset = () => {
          currentBtn?.classList.remove('is-playing');
          current = null;
          currentBtn = null;
        };
        document.querySelectorAll<HTMLButtonElement>('.sfx-btn').forEach((btn) => {
          const src = btn.dataset.audio;
          if (!src) return;
          const audio = new Audio(src);
          audio.addEventListener('ended', reset);
          btn.addEventListener('click', () => {
            if (current === audio) {
              audio.pause();
              audio.currentTime = 0;
              reset();
              return;
            }
            if (current) {
              current.pause();
              current.currentTime = 0;
              currentBtn?.classList.remove('is-playing');
            }
            audio.play().then(() => {
              current = audio;
              currentBtn = btn;
              btn.classList.add('is-playing');
            }).catch(() => {});
          });
        });
      }
    </script>
  </body>
</html>
