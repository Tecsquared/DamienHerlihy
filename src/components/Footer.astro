---
const year = new Date().getFullYear();

const groups = [
  {
    heading: 'Page',
    links: [
      { label: 'Home', href: '/' },
      { label: 'About', href: '/about' },
      { label: 'Now', href: '/now' },
    ],
  },
  {
    heading: 'Universe',
    links: [
      { label: 'Essays', href: '/essays' },
      { label: 'Notes', href: '/notes' },
      { label: 'Library', href: '/library' },
    ],
  },
  {
    heading: 'Connect',
    links: [
      { label: 'Contact', href: '/contact' },
      { label: 'Services', href: '/services' },
      { label: 'YouTube', href: 'https://www.youtube.com/@damienherlihy' },
      { label: 'Language Layouts', href: 'https://www.languagelayouts.com/' },
      { label: 'disASTER', href: 'https://dis-aster.vercel.app' },
    ],
  },
];
---

<footer class="footer">
  <div class="footer-stars" aria-hidden="true">
    <span class="fs" style="left: 8%; top: 24%"></span>
    <span class="fs" style="left: 22%; top: 62%; animation-delay: 0.8s"></span>
    <span class="fs" style="left: 41%; top: 18%; animation-delay: 1.6s"></span>
    <span class="fs" style="left: 58%; top: 70%; animation-delay: 0.4s"></span>
    <span class="fs" style="left: 74%; top: 30%; animation-delay: 2.1s"></span>
    <span class="fs" style="left: 90%; top: 55%; animation-delay: 1.2s"></span>
  </div>

  <div class="footer-inner container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-wordmark">
          <span class="fw-bold">Damien.</span><span class="fw-light">Herlihy</span>
        </a>
        <p class="footer-tag">
          A digital universe of notes, essays &amp; ideas — from a language teacher who never
          stopped being a learner.
        </p>
      </div>

      <nav class="footer-nav" aria-label="Footer">
        {
          groups.map((group) => (
            <div class="footer-col">
              <span class="footer-heading">{group.heading}</span>
              <ul>
                {group.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      target={link.href.startsWith('http') ? '_blank' : undefined}
                      rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>

    <div class="footer-bottom">
      <span class="footer-note">&copy; {year} Damien Herlihy</span>
      <span class="footer-note footer-place">Brisbane &harr; Trat &mdash; under the same sky</span>
      <button class="back-to-top" id="back-to-top" aria-label="Back to the top of the sky">
        <span>Back to the sky</span>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 20 V4 M5 11 L12 4 L19 11"></path>
        </svg>
      </button>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--hairline);
    background: rgba(5, 5, 8, 0.6);
    overflow: hidden;
  }

  .footer-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .fs {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--gold);
    opacity: 0.25;
    animation: fs-twinkle 3.6s ease-in-out infinite;
  }

  @keyframes fs-twinkle {
    0%,
    100% {
      opacity: 0.12;
      transform: scale(0.8);
    }
    50% {
      opacity: 0.55;
      transform: scale(1.2);
    }
  }

  .footer-inner {
    padding-top: clamp(60px, 8vw, 100px);
    padding-bottom: 36px;
    position: relative;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: clamp(40px, 6vw, 100px);
    padding-bottom: clamp(48px, 6vw, 80px);
  }

  .footer-wordmark {
    font-family: var(--font-body);
    font-size: clamp(28px, 3.4vw, 42px);
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .fw-bold {
    font-weight: 600;
  }

  .fw-light {
    font-weight: 300;
    color: var(--ink-dim);
  }

  .footer-tag {
    margin-top: 18px;
    font-size: 15px;
    color: var(--ink-faint);
    max-width: 36ch;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .footer-heading {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 18px;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col a {
    font-size: 15px;
    color: var(--ink-dim);
    transition:
      color 0.35s var(--ease),
      padding-left 0.35s var(--ease);
  }

  .footer-col a:hover {
    color: var(--gold-bright);
    padding-left: 6px;
  }

  .footer-bottom {
    border-top: 1px solid var(--hairline);
    padding-top: 26px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
  }

  .footer-note {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--ink-faint);
  }

  .back-to-top {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: none;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    padding: 10px 18px;
    cursor: pointer;
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition:
      color 0.4s var(--ease),
      border-color 0.4s var(--ease),
      transform 0.4s var(--ease);
  }

  .back-to-top:hover {
    color: var(--gold-bright);
    border-color: var(--gold-dim);
  }

  .back-to-top:active {
    transform: scale(0.96);
  }

  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .footer-nav {
      grid-template-columns: 1fr 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  document.getElementById('back-to-top')?.addEventListener('click', () => {
    const lenis = (window as any).__lenis;
    if (lenis) lenis.scrollTo(0);
    else window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
