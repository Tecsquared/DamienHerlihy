---
interface Props {
  activeCategory?: string;
}

const { activeCategory } = Astro.props;

const categories = [
  { name: 'AI & Teaching', slug: 'ai-and-teaching' },
  { name: 'Personal Knowledge Mgt', slug: 'personal-knowledge-mgt' },
  { name: 'Second Mountain', slug: 'second-mountain' },
  { name: 'Learning How to Learn', slug: 'learning-how-to-learn' },
  { name: 'Languages', slug: 'languages' },
];

const tags = [
  { label: 'Galaxy / Essay', href: '/essays' },
  { label: 'Star / Note', href: '/notes' },
  { label: 'Constellation / Pattern', href: '/notes' },
  { label: 'Library', href: '/library' },
];
---

<aside class="sidebar">
  <div class="sidebar-section">
    <h2 class="sidebar-heading eyebrow">Constellations</h2>
    <ul class="topic-list">
      {
        categories.map((cat) => (
          <li>
            <a
              href={`/category/${cat.slug}`}
              class:list={['topic-link', { active: activeCategory === cat.name }]}
              aria-current={activeCategory === cat.name ? 'page' : undefined}
            >
              <span class="topic-star" aria-hidden="true">
                &#10022;
              </span>
              {cat.name}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="sidebar-section">
    <h2 class="sidebar-heading eyebrow">Kinds of light</h2>
    <div class="tag-pills">
      {tags.map((tag) => <a href={tag.href} class="tag-pill">{tag.label}</a>)}
    </div>
  </div>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: calc(var(--nav-h) + 40px);
  }

  .sidebar-section {
    margin-bottom: 44px;
  }

  .sidebar-heading {
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--hairline);
    width: 100%;
  }

  .topic-list {
    list-style: none;
  }

  .topic-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 0;
    font-size: 15px;
    font-weight: 400;
    color: var(--ink-dim);
    border-bottom: 1px solid var(--hairline);
    transition:
      color 0.35s var(--ease),
      padding-left 0.35s var(--ease);
  }

  .topic-star {
    color: var(--gold);
    font-size: 10px;
    opacity: 0;
    transform: scale(0.5);
    transition:
      opacity 0.35s var(--ease),
      transform 0.35s var(--ease);
  }

  .topic-link:hover {
    color: var(--ink);
    padding-left: 4px;
  }

  .topic-link:hover .topic-star {
    opacity: 1;
    transform: scale(1);
  }

  .topic-link.active {
    color: var(--gold-bright);
  }

  .topic-link.active .topic-star {
    opacity: 1;
    transform: scale(1);
  }

  .tag-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag-pill {
    display: inline-block;
    padding: 8px 16px;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-dim);
    transition:
      color 0.35s var(--ease),
      border-color 0.35s var(--ease),
      background-color 0.35s var(--ease);
  }

  .tag-pill:hover {
    border-color: var(--gold-dim);
    color: var(--gold-bright);
    background: var(--gold-glow);
  }
</style>
