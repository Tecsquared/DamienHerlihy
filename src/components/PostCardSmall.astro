---
import CategoryTag from './CategoryTag.astro';

interface Props {
  title: string;
  category: string;
  slug: string;
  image?: string;
}

const { title, category, slug, image } = Astro.props;
---

<a href={`/post/${slug}`} class="small-card">
  <div class="small-card-image" style={image ? `background-image: url(${image})` : ''}></div>
  <span class="small-card-category">{category}</span>
  <h4 class="small-card-title">{title}</h4>
</a>

<style>
  .small-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    min-width: 160px;
    gap: 8px;
    flex-shrink: 0;
  }

  .small-card-image {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background-color: #e8e8e8;
    background-size: cover;
    background-position: center;
    transition: box-shadow .45s cubic-bezier(.25, .46, .45, .94),
                transform .25s cubic-bezier(.25, .46, .45, .94);
  }

  .small-card:hover .small-card-image {
    box-shadow: 0 50px 80px -20px rgba(0, 0, 0, 0.2);
  }

  .small-card-category {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-light);
  }

  .small-card-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-black);
    line-height: 1.3;
    max-width: 150px;
  }

  .small-card:hover .small-card-title {
    text-decoration: underline;
  }
</style>
