---
import CategoryTag from './CategoryTag.astro';

interface Props {
  title: string;
  category: string;
  date: Date;
  slug: string;
  image?: string;
}

const { title, category, date, slug, image } = Astro.props;

const dateStr = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).toUpperCase();
---

<a href={`/post/${slug}`} class="list-card" data-category={category}>
  <div class="list-card-image-wrapper">
    <div class="list-card-image" style={image ? `background-image: url(${image})` : ''}></div>
  </div>
  <div class="list-card-body">
    <div class="list-card-meta">
      <CategoryTag category={category} />
      <span class="list-card-date">{dateStr}</span>
    </div>
    <h3 class="list-card-title">{title}</h3>
  </div>
</a>

<style>
  .list-card {
    display: flex;
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .list-card:first-child {
    padding-top: 0;
  }

  .list-card-image-wrapper {
    width: 240px;
    flex-shrink: 0;
    border-radius: var(--radius);
    overflow: hidden;
  }

  .list-card-image {
    width: 100%;
    min-height: 180px;
    background-color: #e8e8e8;
    background-size: cover;
    background-position: center;
    transition: transform .3s cubic-bezier(.25, .46, .45, .94);
  }

  .list-card:hover .list-card-image {
    transform: scale(1.05);
  }

  .list-card-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .list-card-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }

  .list-card-date {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--color-text-light);
  }

  .list-card-title {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-black);
    line-height: 1.3;
  }

  .list-card:hover .list-card-title {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .list-card {
      flex-direction: column;
      gap: 16px;
    }

    .list-card-image-wrapper {
      width: 100%;
    }

    .list-card-image {
      aspect-ratio: 16 / 9;
      min-height: auto;
    }

    .list-card-title {
      font-size: 20px;
    }
  }
</style>
