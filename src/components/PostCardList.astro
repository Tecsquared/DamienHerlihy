---
interface Props {
  title: string;
  category: string;
  date: Date;
  slug: string;
  image?: string;
}

const { title, category, date, slug, image } = Astro.props;

const dateStr = date
  .toLocaleDateString('en-AU', { year: 'numeric', month: 'short' })
  .toUpperCase();
---

<a href={`/post/${slug}`} class="list-row">
  <span class="list-date">{dateStr}</span>
  {image && <img class="list-thumb" src={image} alt="" loading="lazy" />}
  <span class="list-body">
    <span class="list-title">{title}</span>
    <span class="list-cat">{category}</span>
  </span>
  <span class="list-arrow" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M4 20 L20 4 M8 4 h12 v12"></path>
    </svg>
  </span>
</a>

<style>
  .list-row {
    display: flex;
    align-items: center;
    gap: clamp(16px, 2.6vw, 32px);
    padding: clamp(20px, 2.6vw, 30px) 6px;
    border-bottom: 1px solid var(--hairline);
    position: relative;
    transition: padding-left 0.5s var(--ease);
  }

  .list-row::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -1px;
    height: 1px;
    width: 100%;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.6s var(--ease);
  }

  .list-row:hover {
    padding-left: 14px;
  }

  .list-row:hover::after {
    transform: scaleX(1);
  }

  .list-date {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--ink-faint);
    flex-shrink: 0;
    width: 74px;
  }

  .list-thumb {
    width: 88px;
    height: 60px;
    object-fit: cover;
    border-radius: var(--r-sm);
    border: 1px solid var(--hairline);
    flex-shrink: 0;
    filter: saturate(0.9);
    transition: filter 0.5s var(--ease);
  }

  .list-row:hover .list-thumb {
    filter: saturate(1);
  }

  .list-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .list-title {
    font-family: var(--font-display);
    font-size: clamp(19px, 2.2vw, 26px);
    line-height: 1.25;
    color: var(--ink);
    transition: color 0.4s var(--ease);
  }

  .list-row:hover .list-title {
    color: var(--gold-bright);
  }

  .list-cat {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .list-arrow {
    margin-left: auto;
    color: var(--ink-faint);
    flex-shrink: 0;
    transition:
      color 0.4s var(--ease),
      transform 0.4s var(--ease);
  }

  .list-arrow svg {
    width: 15px;
    height: 15px;
  }

  .list-row:hover .list-arrow {
    color: var(--gold);
    transform: translate(3px, -3px);
  }

  @media (max-width: 600px) {
    .list-date {
      display: none;
    }

    .list-thumb {
      width: 64px;
      height: 46px;
    }
  }
</style>
