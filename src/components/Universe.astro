---
/*
  The Digital Universe — a living star chart.
  Background: ambient drifting starfield (WebGL points, shader twinkle).
  Foreground: every post is a gold star; each category forms a constellation.
  Hover a star to read its title; click to travel to the post.
*/
interface StarPost {
  title: string;
  slug: string;
  tag: string;
  category: string;
}

interface Props {
  posts: StarPost[];
}

const { posts } = Astro.props;
---

<canvas class="universe-canvas" id="universe-canvas" aria-hidden="true"></canvas>

<div class="star-tip" id="star-tip" role="status" aria-live="polite">
  <span class="star-tip-title" id="star-tip-title"></span>
  <span class="star-tip-meta" id="star-tip-meta"></span>
</div>

<script type="application/json" id="universe-data" set:html={JSON.stringify(posts)} />

<style>
  .universe-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 2.2s ease;
  }

  .universe-canvas.is-on {
    opacity: 1;
  }

  .star-tip {
    position: fixed;
    z-index: var(--z-tip);
    pointer-events: none;
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 12px 16px;
    background: rgba(8, 8, 13, 0.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--hairline-strong);
    border-radius: 12px;
    max-width: 300px;
    opacity: 0;
    transform: translateY(6px) scale(0.96);
    transition:
      opacity 0.3s var(--ease),
      transform 0.3s var(--ease);
  }

  .star-tip.show {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .star-tip-title {
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1.3;
    color: var(--ink);
  }

  .star-tip-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
  }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('universe-canvas') as HTMLCanvasElement;
  const tip = document.getElementById('star-tip')!;
  const tipTitle = document.getElementById('star-tip-title')!;
  const tipMeta = document.getElementById('star-tip-meta')!;

  const posts: { title: string; slug: string; tag: string; category: string }[] = JSON.parse(
    document.getElementById('universe-data')!.textContent || '[]'
  );

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const finePointer = window.matchMedia('(pointer: fine)').matches;

  function tagLabel(tag: string) {
    if (tag.startsWith('Galaxy')) return 'Essay';
    if (tag.startsWith('Star')) return 'Note';
    if (tag.startsWith('Constellation')) return 'Pattern';
    return 'Library';
  }

  // Deterministic pseudo-random from a string, so the sky map is stable.
  function hash(str: string) {
    let h = 2166136261;
    for (let i = 0; i < str.length; i++) {
      h ^= str.charCodeAt(i);
      h = Math.imul(h, 16777619);
    }
    return () => {
      h = Math.imul(h ^ (h >>> 15), 2246822507);
      h = Math.imul(h ^ (h >>> 13), 3266489909);
      return ((h ^= h >>> 16) >>> 0) / 4294967296;
    };
  }

  function init() {
    let renderer: THREE.WebGLRenderer;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    } catch {
      canvas.remove();
      return;
    }

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(55, innerWidth / innerHeight, 0.1, 600);
    camera.position.z = 130;

    const dprCap = innerWidth < 768 ? 1.5 : 2;
    renderer.setPixelRatio(Math.min(devicePixelRatio, dprCap));
    renderer.setSize(innerWidth, innerHeight);

    /* ---------- Ambient starfield ---------- */
    const isMobile = innerWidth < 768;
    const STAR_COUNT = isMobile ? 450 : 1100;
    const rand = hash('the-night-sky');

    const positions = new Float32Array(STAR_COUNT * 3);
    const sizes = new Float32Array(STAR_COUNT);
    const phases = new Float32Array(STAR_COUNT);
    const speeds = new Float32Array(STAR_COUNT);

    for (let i = 0; i < STAR_COUNT; i++) {
      positions[i * 3] = (rand() - 0.5) * 340;
      positions[i * 3 + 1] = (rand() - 0.5) * 220;
      positions[i * 3 + 2] = -20 - rand() * 180;
      sizes[i] = 0.7 + rand() * 1.9;
      phases[i] = rand();
      speeds[i] = 0.3 + rand() * 1.4;
    }

    const starGeo = new THREE.BufferGeometry();
    starGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    starGeo.setAttribute('aSize', new THREE.BufferAttribute(sizes, 1));
    starGeo.setAttribute('aPhase', new THREE.BufferAttribute(phases, 1));
    starGeo.setAttribute('aSpeed', new THREE.BufferAttribute(speeds, 1));

    const starMat = new THREE.ShaderMaterial({
      transparent: true,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
      uniforms: {
        uTime: { value: 0 },
        uPx: { value: Math.min(devicePixelRatio, dprCap) },
      },
      vertexShader: `
        attribute float aSize;
        attribute float aPhase;
        attribute float aSpeed;
        varying float vPhase;
        varying float vSpeed;
        uniform float uPx;
        void main() {
          vPhase = aPhase;
          vSpeed = aSpeed;
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          gl_PointSize = aSize * uPx * (160.0 / -mv.z);
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        uniform float uTime;
        varying float vPhase;
        varying float vSpeed;
        void main() {
          float d = distance(gl_PointCoord, vec2(0.5));
          float core = smoothstep(0.5, 0.04, d);
          float tw = 0.55 + 0.45 * sin(uTime * vSpeed + vPhase * 6.28318);
          vec3 warm = vec3(0.93, 0.91, 0.86);
          vec3 cool = vec3(0.74, 0.78, 0.95);
          vec3 col = mix(warm, cool, step(0.55, fract(vPhase * 7.31)));
          gl_FragColor = vec4(col, core * tw * 0.85);
        }
      `,
    });

    const starField = new THREE.Points(starGeo, starMat);
    scene.add(starField);

    /* ---------- Post stars: the constellations ---------- */
    const categories = [...new Set(posts.map((p) => p.category))].sort();
    const aspect = innerWidth / innerHeight;
    const squeeze = Math.min(1, aspect / 1.45);

    // Camera half-extents at the z ≈ 0 star plane (camera z = 130, fov 55),
    // so phone clusters can be placed as viewport fractions.
    const halfH = Math.tan((55 / 2) * (Math.PI / 180)) * 130;
    const halfW = halfH * aspect;

    // Phones lack the desktop's free upper sky — the hero copy fills most of
    // the frame, so the same anchors would put stars behind the headline.
    const portraitPhone = innerWidth < 768 && innerHeight > innerWidth;
    const shortLandscape = innerHeight < 520 && innerWidth > innerHeight;

    // Loose cluster anchors. Desktop: across the upper sky (hero text sits
    // lower-left). Portrait phones: the band below the CTA buttons, beside
    // the legend caption. Short landscape: the same upper sky, raised a
    // little clear of the bottom-anchored title.
    const anchors = portraitPhone
      ? [
          { fx: -0.55, fy: -0.3 },
          { fx: 0.1, fy: -0.44 },
          { fx: 0.58, fy: -0.3 },
          { fx: -0.2, fy: -0.62 },
          { fx: 0.5, fy: -0.64 },
          { fx: -0.6, fy: -0.5 },
        ].map((a) => ({ x: a.fx * halfW, y: a.fy * halfH }))
      : [
          { x: -52, y: 30 },
          { x: -12, y: 42 },
          { x: 28, y: 32 },
          { x: 56, y: 14 },
          { x: 8, y: 14 },
          { x: -34, y: 6 },
        ].map((a) => ({ x: a.x, y: a.y + (shortLandscape ? 12 : 0) }));

    // On small screens the gold stars share space with some caption text —
    // pull their brightness back so type always wins.
    const fadeCap = portraitPhone || shortLandscape ? 0.75 : 1;

    const postGroup = new THREE.Group();
    scene.add(postGroup);

    const postPositions = new Float32Array(posts.length * 3);
    const postScales = new Float32Array(posts.length);
    const targetScales = new Float32Array(posts.length);
    const postWorld: THREE.Vector3[] = [];

    posts.forEach((post, i) => {
      const ci = categories.indexOf(post.category) % anchors.length;
      const anchor = anchors[ci];
      const r = hash(post.slug);
      // Portrait anchors are already viewport-fraction based — squeezing
      // them again would collapse the clusters into a single column.
      const jx = portraitPhone ? 0.24 * halfW : 26;
      const jy = portraitPhone ? 0.11 * halfH : 20;
      const x = (anchor.x + (r() - 0.5) * jx) * (portraitPhone ? 1 : squeeze);
      const y = anchor.y + (r() - 0.5) * jy;
      const z = (r() - 0.5) * 16;
      postPositions[i * 3] = x;
      postPositions[i * 3 + 1] = y;
      postPositions[i * 3 + 2] = z;
      const base = post.tag.startsWith('Galaxy') ? 30 : post.tag === 'Library' ? 18 : 14;
      postScales[i] = base;
      targetScales[i] = base;
      postWorld.push(new THREE.Vector3(x, y, z));
    });

    const postGeo = new THREE.BufferGeometry();
    postGeo.setAttribute('position', new THREE.BufferAttribute(postPositions, 3));
    postGeo.setAttribute('aScale', new THREE.BufferAttribute(postScales, 1));

    const postMat = new THREE.ShaderMaterial({
      transparent: true,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
      uniforms: {
        uTime: { value: 0 },
        uPx: { value: Math.min(devicePixelRatio, dprCap) },
        uFade: { value: 0 },
      },
      vertexShader: `
        attribute float aScale;
        varying float vSeed;
        uniform float uPx;
        void main() {
          vSeed = position.x * 0.37 + position.y * 0.91;
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          gl_PointSize = aScale * uPx * (140.0 / -mv.z);
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        uniform float uTime;
        uniform float uFade;
        varying float vSeed;
        void main() {
          vec2 uv = gl_PointCoord - 0.5;
          float d = length(uv);
          float core = smoothstep(0.16, 0.0, d);
          float glow = smoothstep(0.5, 0.0, d) * 0.32;
          float fh = smoothstep(0.5, 0.0, abs(uv.y) * 16.0) * smoothstep(0.5, 0.0, d);
          float fv = smoothstep(0.5, 0.0, abs(uv.x) * 16.0) * smoothstep(0.5, 0.0, d);
          float pulse = 0.85 + 0.15 * sin(uTime * 1.4 + vSeed);
          float a = (core + glow + (fh + fv) * 0.55) * pulse * uFade;
          vec3 gold = vec3(0.92, 0.74, 0.38);
          gl_FragColor = vec4(gold, a);
        }
      `,
    });

    const postStars = new THREE.Points(postGeo, postMat);
    postGroup.add(postStars);

    /* ---------- Constellation lines (per category, in date order) ---------- */
    const lineMats: THREE.LineBasicMaterial[] = [];
    const lineByCategory = new Map<string, THREE.LineBasicMaterial>();
    const lines: { line: THREE.Line; total: number; cat: string }[] = [];

    categories.forEach((cat) => {
      const idxs = posts.map((p, i) => ({ p, i })).filter(({ p }) => p.category === cat);
      if (idxs.length < 2) return;
      const pts = idxs.map(({ i }) => postWorld[i]);
      const geo = new THREE.BufferGeometry().setFromPoints(pts);
      const mat = new THREE.LineBasicMaterial({
        color: 0xd9a94f,
        transparent: true,
        opacity: 0,
      });
      const line = new THREE.Line(geo, mat);
      line.geometry.setDrawRange(0, 0);
      postGroup.add(line);
      lineMats.push(mat);
      lineByCategory.set(cat, mat);
      lines.push({ line, total: pts.length, cat });
    });

    /* ---------- Shooting stars ---------- */
    const meteorGeo = new THREE.BufferGeometry().setFromPoints([
      new THREE.Vector3(),
      new THREE.Vector3(),
    ]);
    const meteorMat = new THREE.LineBasicMaterial({
      color: 0xeceae3,
      transparent: true,
      opacity: 0,
    });
    const meteor = new THREE.Line(meteorGeo, meteorMat);
    scene.add(meteor);

    let meteorLife = -1;
    let meteorNext = 4;
    const meteorStart = new THREE.Vector3();
    const meteorVel = new THREE.Vector3();

    function spawnMeteor() {
      meteorStart.set((Math.random() - 0.5) * 200, 60 + Math.random() * 40, -60);
      meteorVel.set(-(30 + Math.random() * 40), -(20 + Math.random() * 25), 0);
      meteorLife = 0;
    }

    /* ---------- Interaction ---------- */
    const raycaster = new THREE.Raycaster();
    // Fingers are blunter than cursors — widen the hit area on touch.
    raycaster.params.Points.threshold = finePointer ? 4 : 7;
    const pointer = new THREE.Vector2(-10, -10);
    let pointerPx = { x: 0, y: 0 };
    let hovered = -1;
    let parallaxX = 0;
    let parallaxY = 0;

    const heroActive = () => scrollY < innerHeight * 0.75;

    window.addEventListener(
      'pointermove',
      (e) => {
        pointerPx = { x: e.clientX, y: e.clientY };
        pointer.x = (e.clientX / innerWidth) * 2 - 1;
        pointer.y = -(e.clientY / innerHeight) * 2 + 1;
        parallaxX = pointer.x;
        parallaxY = pointer.y;
      },
      { passive: true }
    );

    function setHover(i: number) {
      if (i === hovered) return;
      hovered = i;
      for (let k = 0; k < posts.length; k++) {
        const base = posts[k].tag.startsWith('Galaxy') ? 30 : posts[k].tag === 'Library' ? 18 : 14;
        targetScales[k] = k === i ? base * 1.8 : base;
      }
      lines.forEach(({ cat }) => {
        const mat = lineByCategory.get(cat)!;
        if (i === -1) mat.opacity = 0.16;
        else mat.opacity = posts[i].category === cat ? 0.5 : 0.05;
      });
      if (i >= 0) {
        tipTitle.textContent = posts[i].title;
        tipMeta.textContent =
          `${tagLabel(posts[i].tag)} ✦ ${posts[i].category}` +
          (finePointer ? '' : ' · tap again to open');
        tip.classList.add('show');
        document.body.style.cursor = 'pointer';
      } else {
        tip.classList.remove('show');
        document.body.style.cursor = '';
      }
    }

    // Pick the star nearest the cursor (smallest distanceToRay), not the
    // one nearest the camera — otherwise stars that cluster in the same
    // constellation shadow each other and share one tooltip.
    function pickStar() {
      raycaster.setFromCamera(pointer, camera);
      const hits = raycaster.intersectObject(postStars);
      let pick = -1;
      let bestRayDist = Infinity;
      for (const h of hits) {
        const d = h.distanceToRay ?? Infinity;
        if (d < bestRayDist) {
          bestRayDist = d;
          pick = h.index ?? -1;
        }
      }
      return pick;
    }

    window.addEventListener('click', (e) => {
      if (!heroActive()) return;
      const el = e.target as HTMLElement;
      if (el.closest('a, button, input, textarea, [data-block-stars]')) return;

      if (finePointer) {
        if (hovered >= 0) location.href = `/post/${posts[hovered].slug}`;
        return;
      }

      // Touch: first tap selects a star and shows the tooltip; a second tap
      // on the same star opens it. Tapping empty sky dismisses.
      pointer.x = (e.clientX / innerWidth) * 2 - 1;
      pointer.y = -(e.clientY / innerHeight) * 2 + 1;
      const pick = pickStar();
      if (pick >= 0 && pick === hovered) {
        location.href = `/post/${posts[pick].slug}`;
        return;
      }
      setHover(pick);
      if (pick >= 0) {
        tip.style.left = `${Math.min(e.clientX + 18, innerWidth - 320)}px`;
        tip.style.top = `${Math.min(e.clientY + 18, innerHeight - 96)}px`;
      }
      if (reducedMotion) {
        // No frame loop under reduced motion — apply the swell and repaint once.
        const attr = postGeo.getAttribute('aScale') as THREE.BufferAttribute;
        for (let i = 0; i < posts.length; i++) attr.setX(i, targetScales[i]);
        attr.needsUpdate = true;
        renderer.render(scene, camera);
      }
    });

    /* ---------- Scroll response ---------- */
    let scrollFade = 1;
    function onScroll() {
      const t = Math.min(1, scrollY / (innerHeight * 0.9));
      scrollFade = 1 - t;
      postGroup.position.y = scrollY * 0.02;
      starField.position.y = scrollY * 0.008;
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    /* ---------- Loop ---------- */
    const t0 = performance.now();
    const now = () => (performance.now() - t0) / 1000;
    let running = true;
    let lastT = 0;

    function frame() {
      const t = now();
      const dt = Math.min(0.05, t - lastT || 0.016);
      lastT = t;
      starMat.uniforms.uTime.value = t;
      postMat.uniforms.uTime.value = t;
      postMat.uniforms.uFade.value +=
        (Math.max(0.15, scrollFade) * fadeCap - postMat.uniforms.uFade.value) * 0.04;

      // Pointer parallax with easing
      camera.position.x += (parallaxX * 5 - camera.position.x) * 0.03;
      camera.position.y += (parallaxY * 3 - camera.position.y) * 0.03;
      camera.lookAt(0, 0, -40);

      // Slow drift
      starField.rotation.z = t * 0.004;

      // Hover scale easing
      let dirty = false;
      const attr = postGeo.getAttribute('aScale') as THREE.BufferAttribute;
      for (let i = 0; i < posts.length; i++) {
        const cur = attr.getX(i);
        const next = cur + (targetScales[i] - cur) * 0.12;
        if (Math.abs(next - cur) > 0.01) {
          attr.setX(i, next);
          dirty = true;
        }
      }
      if (dirty) attr.needsUpdate = true;

      // Constellation draw-in
      lines.forEach(({ line, total }, li) => {
        const elapsed = t - 1 - li * 0.35;
        if (elapsed > 0) {
          const n = Math.min(total, Math.floor(elapsed * 6) + 1);
          line.geometry.setDrawRange(0, n);
          const mat = line.material as THREE.LineBasicMaterial;
          if (hovered === -1 && mat.opacity < 0.16) mat.opacity += dt * 0.1;
        }
      });

      // Meteors
      if (!reducedMotion) {
        if (meteorLife < 0) {
          meteorNext -= dt;
          if (meteorNext <= 0) {
            spawnMeteor();
            meteorNext = 6 + Math.random() * 9;
          }
        } else {
          meteorLife += dt;
          const k = meteorLife / 1.1;
          if (k >= 1) {
            meteorLife = -1;
            meteorMat.opacity = 0;
          } else {
            const head = meteorStart.clone().addScaledVector(meteorVel, k * 1.1);
            const tail = head.clone().addScaledVector(meteorVel, -0.22);
            const pos = meteorGeo.getAttribute('position') as THREE.BufferAttribute;
            pos.setXYZ(0, tail.x, tail.y, tail.z);
            pos.setXYZ(1, head.x, head.y, head.z);
            pos.needsUpdate = true;
            meteorMat.opacity = Math.sin(k * Math.PI) * 0.7;
          }
        }
      }

      // Raycast hover (hero only, fine pointers only — touch selects via tap)
      if (heroActive() && finePointer) {
        setHover(pickStar());
        if (hovered >= 0) {
          tip.style.left = `${Math.min(pointerPx.x + 18, innerWidth - 320)}px`;
          tip.style.top = `${pointerPx.y + 18}px`;
        }
      } else if (hovered !== -1 && (finePointer || !heroActive())) {
        // Touch selections persist until a tap elsewhere or a scroll away.
        setHover(-1);
      }

      renderer.render(scene, camera);
      if (running && !reducedMotion) requestAnimationFrame(frame);
    }

    /* Reduced motion: draw the finished sky once, no animation */
    if (reducedMotion) {
      postMat.uniforms.uFade.value = fadeCap;
      lines.forEach(({ line, total }) => {
        line.geometry.setDrawRange(0, total);
        (line.material as THREE.LineBasicMaterial).opacity = 0.16;
      });
      renderer.render(scene, camera);
    } else {
      requestAnimationFrame(frame);
    }

    canvas.classList.add('is-on');

    document.addEventListener('visibilitychange', () => {
      if (reducedMotion) return;
      if (document.hidden) {
        running = false;
      } else if (!running) {
        running = true;
        lastT = now();
        requestAnimationFrame(frame);
      }
    });

    window.addEventListener('resize', () => {
      camera.aspect = innerWidth / innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(innerWidth, innerHeight);
      renderer.setPixelRatio(Math.min(devicePixelRatio, dprCap));
      if (reducedMotion) renderer.render(scene, camera);
    });
  }

  init();
</script>
