---
interface Props {
  category: string;
  variant?: 'light' | 'dark';
}

const { category } = Astro.props;
---

<span class="category-tag">
  <span class="category-tag-star" aria-hidden="true">&#10022;</span>
  {category}
</span>

<style>
  .category-tag {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    padding: 5px 12px;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    color: var(--ink-dim);
    white-space: nowrap;
  }

  .category-tag-star {
    color: var(--gold);
    font-size: 9px;
  }
</style>
