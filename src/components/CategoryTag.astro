---
interface Props {
  category: string;
  variant?: 'light' | 'dark';
}

const { category, variant = 'light' } = Astro.props;
---

<span class:list={['category-tag', `category-tag--${variant}`]}>
  {category}
</span>

<style>
  .category-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 6px 10px;
    border-radius: 4px;
    white-space: nowrap;
  }

  .category-tag--light {
    background: var(--color-tag-bg);
    color: var(--color-black);
  }

  .category-tag--dark {
    background: #ffffff;
    color: var(--color-black);
  }
</style>
