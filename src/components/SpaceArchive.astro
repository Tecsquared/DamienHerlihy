---
/*
  The Space Archive — a slow lateral drift through the back catalogue.
  Art direction: chalky hand-drawn night sky (deep indigo, pastel aurora
  veils, grainy stars, warm cream star-glows) + the NatGeo "Black Holes 101"
  diagram language (one elegant spacetime line, spaced mono typography,
  a gold dashed light-line, the black hole as a gravity-well funnel).

  Scroll drifts you sideways past every post — each one a shimmering warm
  star with a plaque — until the line dips into the well and the camera
  sinks down to the dark star at the bottom.

  Desktop + fine-motion only: phones and prefers-reduced-motion visitors
  stay on the flat list rendered by archive.astro. No JS = flat list.
*/
interface FlightPost {
  title: string;
  slug: string;
  category: string;
  tag: string;
  description: string;
  image: string;
  year: number;
  dateLabel: string;
}

interface Props {
  posts: FlightPost[];
  range: string;
}

const { posts, range } = Astro.props;
---

<script type="application/json" id="flight-data" set:html={JSON.stringify(posts)} />

<!-- Scroll track: gives the document its journey length while drifting -->
<div class="flight-track" id="flight-track" aria-hidden="true"></div>

<canvas class="flight-canvas" id="flight-canvas" aria-hidden="true"></canvas>

<!-- Visor -->
<div class="visor" id="visor" aria-hidden="true">
  <div class="visor-edge visor-edge-l"></div>
  <div class="visor-edge visor-edge-r"></div>
  <div class="visor-vignette"></div>
</div>

<!-- HUD -->
<div class="hud" id="hud" aria-hidden="true">
  <div class="hud-readout">
    <span class="hud-line hud-title">✦ THE ARCHIVE</span>
    <span class="hud-line" id="hud-sector">CALIBRATING…</span>
  </div>
  <div class="hud-gauge">
    <div class="hud-gauge-fill" id="hud-gauge-fill"></div>
    <span class="hud-gauge-label hud-gauge-now">NOW</span>
    <span class="hud-gauge-label hud-gauge-horizon">EVENT HORIZON</span>
  </div>
  <div class="hud-hint" id="hud-hint">SCROLL TO DRIFT · CLICK A STAR TO INSPECT</div>
  <div class="hud-controls">
    <button class="hud-btn" id="mute-btn" type="button" aria-label="Toggle sound">SOUND ON</button>
    <button class="hud-btn" id="exit-flight" type="button">FLAT VIEW</button>
  </div>
</div>

<!-- Star preview card -->
<aside class="focus-card" id="focus-card" aria-hidden="true">
  <button class="focus-close" id="focus-close" type="button" aria-label="Close preview">×</button>
  <span class="focus-meta eyebrow" id="focus-meta"></span>
  <h3 class="focus-title" id="focus-title"></h3>
  <span class="focus-date" id="focus-date"></span>
  <p class="focus-desc" id="focus-desc"></p>
  <a class="btn focus-read" id="focus-read" href="/">Read the transmission</a>
</aside>

<!-- End of the line -->
<div class="end-card" id="end-card" aria-hidden="true">
  <span class="eyebrow">✦ END OF TRANSMISSION</span>
  <h3 class="end-title">You've reached the <em>event horizon</em></h3>
  <p class="end-copy">Nothing older survives past this point. Everything else has already fallen in.</p>
  <div class="end-actions">
    <button class="hud-btn" id="return-launch" type="button">RETURN TO LAUNCH</button>
    <button class="hud-btn" id="end-flat" type="button">FLAT VIEW</button>
  </div>
</div>

<!-- Launch gate -->
<div class="gate" id="gate" aria-hidden="true">
  <span class="eyebrow gate-eyebrow">✦ DAMIEN.HERLIHY PRESENTS</span>
  <h2 class="gate-title">The <em>Archive</em></h2>
  <p class="gate-sub">
    {posts.length} transmissions · {range} · drifting toward the event horizon
  </p>
  <button class="btn gate-launch" id="gate-launch" type="button" disabled>Calibrating…</button>
  <button class="gate-skip" id="gate-skip" type="button">or browse the flat archive</button>
  <span class="gate-hint">SCROLL TO DRIFT · MOUSE TO LOOK · CLICK A STAR TO INSPECT</span>
</div>

<style>
  .flight-track {
    display: none;
    width: 1px;
  }

  .flight-canvas {
    display: none;
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    opacity: 0;
    transition: opacity 1.6s ease;
  }

  body.flying .flight-track {
    display: block;
  }

  body.flying .flight-canvas {
    display: block;
  }

  .flight-canvas.is-on {
    opacity: 1;
  }

  /* ===== Gate ===== */
  .gate {
    position: fixed;
    inset: 0;
    z-index: 500;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 18px;
    text-align: center;
    padding: 24px;
    background:
      radial-gradient(ellipse 70% 55% at 50% 42%, rgba(217, 169, 79, 0.07), transparent 70%),
      #0e0e1e;
    opacity: 0;
    transition: opacity 0.9s ease;
  }

  .gate.show {
    display: flex;
    opacity: 1;
  }

  .gate.leaving {
    opacity: 0;
    pointer-events: none;
  }

  .gate-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(52px, 9vw, 110px);
    line-height: 1.02;
    color: var(--ink);
    margin: 0;
  }

  .gate-title em {
    font-style: italic;
    color: var(--gold);
  }

  .gate-sub {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin: 0 0 14px;
  }

  .gate-launch {
    min-width: 220px;
    justify-content: center;
  }

  .gate-skip {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--ink-faint);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.3s var(--ease);
  }

  .gate-skip:hover {
    color: var(--ink);
  }

  .gate-hint {
    position: absolute;
    bottom: 34px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--ink-faint);
  }

  /* ===== Visor ===== */
  .visor {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 80;
    pointer-events: none;
  }

  body.flying .visor {
    display: block;
  }

  .visor-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 92% 88% at 50% 50%, transparent 62%, rgba(6, 6, 14, 0.55) 100%);
  }

  .visor-edge {
    position: absolute;
    top: -12vh;
    bottom: -12vh;
    width: 22vw;
    border: 1px solid rgba(236, 234, 227, 0.05);
  }

  .visor-edge-l {
    left: -14vw;
    border-radius: 0 50% 50% 0;
    background: linear-gradient(to right, rgba(10, 10, 22, 0.5), transparent 70%);
  }

  .visor-edge-r {
    right: -14vw;
    border-radius: 50% 0 0 50%;
    background: linear-gradient(to left, rgba(10, 10, 22, 0.5), transparent 70%);
  }

  /* ===== HUD ===== */
  .hud {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 90;
    pointer-events: none;
  }

  body.flying .hud {
    display: block;
  }

  .hud-readout {
    position: absolute;
    left: clamp(20px, 4vw, 48px);
    top: 96px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .hud-line {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--ink-faint);
  }

  .hud-title {
    color: var(--gold);
  }

  .hud-gauge {
    position: absolute;
    right: clamp(20px, 3vw, 40px);
    top: 50%;
    transform: translateY(-50%);
    width: 2px;
    height: 34vh;
    background: var(--hairline);
  }

  .hud-gauge-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: var(--gold);
    box-shadow: 0 0 8px var(--gold-glow);
  }

  .hud-gauge-label {
    position: absolute;
    right: 10px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .hud-gauge-now {
    top: -4px;
  }

  .hud-gauge-horizon {
    bottom: -4px;
  }

  .hud-hint {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--ink-faint);
    transition: opacity 1s ease;
  }

  .hud-hint.gone {
    opacity: 0;
  }

  .hud-controls {
    position: absolute;
    right: clamp(20px, 3vw, 40px);
    bottom: 26px;
    display: flex;
    gap: 10px;
    pointer-events: auto;
  }

  .hud-btn {
    pointer-events: auto;
    background: rgba(10, 10, 22, 0.6);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--hairline-strong);
    border-radius: 999px;
    padding: 9px 16px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--ink-dim);
    cursor: pointer;
    transition:
      color 0.3s var(--ease),
      border-color 0.3s var(--ease);
  }

  .hud-btn:hover {
    color: var(--gold-bright);
    border-color: var(--gold-dim);
  }

  /* ===== Focus card ===== */
  .focus-card {
    position: fixed;
    z-index: 120;
    top: 50%;
    right: clamp(24px, 7vw, 110px);
    transform: translateY(-50%) translateX(24px);
    width: min(400px, 84vw);
    padding: 30px 30px 28px;
    background: rgba(10, 10, 22, 0.78);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid var(--hairline-strong);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.5s var(--ease),
      transform 0.5s var(--ease);
  }

  .focus-card.show {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(-50%) translateX(0);
  }

  .focus-close {
    position: absolute;
    top: 12px;
    right: 16px;
    background: none;
    border: none;
    color: var(--ink-faint);
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    transition: color 0.3s var(--ease);
  }

  .focus-close:hover {
    color: var(--ink);
  }

  .focus-meta {
    color: var(--gold);
  }

  .focus-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(22px, 2.4vw, 30px);
    line-height: 1.2;
    color: var(--ink);
    margin: 0;
  }

  .focus-date {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--ink-faint);
  }

  .focus-desc {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-dim);
    margin: 0;
  }

  .focus-read {
    align-self: flex-start;
    margin-top: 6px;
  }

  /* ===== End card ===== */
  .end-card {
    position: fixed;
    z-index: 110;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -46%);
    width: min(520px, 88vw);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding: 40px 34px;
    background: rgba(10, 10, 22, 0.7);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--hairline-strong);
    border-radius: 18px;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.8s var(--ease),
      transform 0.8s var(--ease);
  }

  .end-card.show {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, -50%);
  }

  .end-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(26px, 3.4vw, 38px);
    line-height: 1.15;
    color: var(--ink);
    margin: 0;
  }

  .end-title em {
    font-style: italic;
    color: var(--gold);
  }

  .end-copy {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--ink-dim);
    margin: 0 0 8px;
  }

  .end-actions {
    display: flex;
    gap: 10px;
  }

  /* Hide footer while drifting; the void needs no footer */
  :global(body.flying footer) {
    display: none;
  }

  /* No-JS never sees any of this */
  :global(html:not(.js)) .gate,
  :global(html:not(.js)) .flight-canvas {
    display: none !important;
  }
</style>

<script>
  import * as THREE from 'three';
  import gsap from 'gsap';

  interface FlightPost {
    title: string;
    slug: string;
    category: string;
    tag: string;
    description: string;
    image: string;
    year: number;
    dateLabel: string;
  }

  const posts: FlightPost[] = JSON.parse(
    document.getElementById('flight-data')!.textContent || '[]'
  );

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const bigScreen = window.matchMedia('(min-width: 900px)').matches;

  const canvas = document.getElementById('flight-canvas') as HTMLCanvasElement;
  const gate = document.getElementById('gate')!;
  const gateLaunch = document.getElementById('gate-launch') as HTMLButtonElement;
  const gateSkip = document.getElementById('gate-skip')!;
  const track = document.getElementById('flight-track')!;
  const hudSector = document.getElementById('hud-sector')!;
  const hudGaugeFill = document.getElementById('hud-gauge-fill')!;
  const hudHint = document.getElementById('hud-hint')!;
  const muteBtn = document.getElementById('mute-btn')!;
  const exitBtn = document.getElementById('exit-flight')!;
  const focusCard = document.getElementById('focus-card')!;
  const focusClose = document.getElementById('focus-close')!;
  const focusMeta = document.getElementById('focus-meta')!;
  const focusTitle = document.getElementById('focus-title')!;
  const focusDate = document.getElementById('focus-date')!;
  const focusDesc = document.getElementById('focus-desc')!;
  const focusRead = document.getElementById('focus-read') as HTMLAnchorElement;
  const endCard = document.getElementById('end-card')!;
  const returnLaunch = document.getElementById('return-launch')!;
  const endFlat = document.getElementById('end-flat')!;
  const invite = document.getElementById('flight-invite')!;
  const relaunch = document.getElementById('relaunch-flight')!;
  const flatSection = document.getElementById('flat-archive')!;

  function webglOk() {
    try {
      const c = document.createElement('canvas');
      return !!(c.getContext('webgl2') || c.getContext('webgl'));
    } catch {
      return false;
    }
  }

  const eligible = !reducedMotion && bigScreen && posts.length > 0 && webglOk();

  function tagLabel(tag: string) {
    if (tag.startsWith('Galaxy')) return 'Essay';
    if (tag.startsWith('Star')) return 'Note';
    if (tag.startsWith('Constellation')) return 'Pattern';
    return 'Library';
  }

  /* Chalky night-sky palette (from the pastel reference) */
  const INK = '#eceae3';
  const GOLD = '#d9a94f';
  const CREAM = '#f5ecd8';
  const PEACH = '#e8a86b';
  const AURORA_TEAL = '#6fae9f';
  const AURORA_LAVENDER = '#8d80b8';

  /* =========================================================
     Audio — synthesised, no files. A low hum, nothing else.
     ========================================================= */
  function makeAudio() {
    const ctx = new AudioContext();
    const master = ctx.createGain();
    master.gain.value = 1;
    master.connect(ctx.destination);

    // Deep hum: filtered noise + low sine
    const noiseBuf = ctx.createBuffer(1, ctx.sampleRate * 2, ctx.sampleRate);
    const data = noiseBuf.getChannelData(0);
    let last = 0;
    for (let i = 0; i < data.length; i++) {
      const white = Math.random() * 2 - 1;
      last = (last + 0.02 * white) / 1.02; // brown-ish noise
      data[i] = last * 3.5;
    }
    const noise = ctx.createBufferSource();
    noise.buffer = noiseBuf;
    noise.loop = true;
    const lowpass = ctx.createBiquadFilter();
    lowpass.type = 'lowpass';
    lowpass.frequency.value = 110;
    const noiseGain = ctx.createGain();
    noiseGain.gain.value = 0.04;
    noise.connect(lowpass).connect(noiseGain).connect(master);
    noise.start();

    const drone = ctx.createOscillator();
    drone.type = 'sine';
    drone.frequency.value = 48;
    const droneGain = ctx.createGain();
    droneGain.gain.value = 0.024;
    drone.connect(droneGain).connect(master);
    drone.start();

    // Slow breathing on the filter
    const lfo = ctx.createOscillator();
    lfo.frequency.value = 0.06;
    const lfoGain = ctx.createGain();
    lfoGain.gain.value = 35;
    lfo.connect(lfoGain).connect(lowpass.frequency);
    lfo.start();

    return {
      ctx,
      setMuted(m: boolean) {
        master.gain.linearRampToValueAtTime(m ? 0 : 1, ctx.currentTime + 0.3);
      },
    };
  }

  /* =========================================================
     The drift
     ========================================================= */
  function init() {
    gate.classList.add('show');
    gate.setAttribute('aria-hidden', 'false');
    invite.hidden = false;

    let renderer: THREE.WebGLRenderer;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
    } catch {
      gate.classList.remove('show');
      invite.hidden = true;
      return;
    }

    const dprCap = 2;
    renderer.setPixelRatio(Math.min(devicePixelRatio, dprCap));
    renderer.setSize(innerWidth, innerHeight);
    renderer.setClearColor(0x0e0e1e, 1);

    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x0e0e1e, 0.0022);

    const camera = new THREE.PerspectiveCamera(55, innerWidth / innerHeight, 0.1, 1200);

    /* ---------- Journey geometry (lateral, along +X) ---------- */
    const STEP = 150;
    const X_FIRST = 240;
    const xLast = X_FIRST + (posts.length - 1) * STEP;
    const xWell = xLast + 380; // funnel centre
    const X_END = xWell - 40; // camera stop, hanging above the well
    const X_START = 0;
    const CAM_DIST = 96;

    // The spacetime line: gentle chalky undulation, then the gravity-well dip
    const baseY = (x: number) => -20 + Math.sin(x * 0.006) * 4;
    const wellDip = (x: number) => {
      const d = (x - xWell) / 85;
      return -150 * Math.exp(-d * d);
    };
    const lineY = (x: number) => baseY(x) + wellDip(x);

    /* ---------- Deterministic randomness ---------- */
    function hash(str: string) {
      let h = 2166136261;
      for (let i = 0; i < str.length; i++) {
        h ^= str.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return () => {
        h = Math.imul(h ^ (h >>> 15), 2246822507);
        h = Math.imul(h ^ (h >>> 13), 3266489909);
        return ((h ^= h >>> 16) >>> 0) / 4294967296;
      };
    }

    /* ---------- Texture helpers (canvas-drawn, chalky) ---------- */
    function radialGlowTexture(inner: string, outer: string, hardness = 0.0) {
      const c = document.createElement('canvas');
      c.width = c.height = 256;
      const g = c.getContext('2d')!;
      const grad = g.createRadialGradient(128, 128, 0, 128, 128, 128);
      grad.addColorStop(0, inner);
      grad.addColorStop(Math.max(0.01, hardness), inner);
      grad.addColorStop(1, outer);
      g.fillStyle = grad;
      g.fillRect(0, 0, 256, 256);
      return new THREE.CanvasTexture(c);
    }

    // A warm hand-drawn star: soft peach halo, cream five-point star core
    function postStarTexture() {
      const c = document.createElement('canvas');
      c.width = c.height = 256;
      const g = c.getContext('2d')!;
      let grad = g.createRadialGradient(128, 128, 0, 128, 128, 128);
      grad.addColorStop(0, 'rgba(232, 168, 107, 0.85)');
      grad.addColorStop(0.35, 'rgba(220, 140, 90, 0.30)');
      grad.addColorStop(1, 'rgba(220, 140, 90, 0)');
      g.fillStyle = grad;
      g.fillRect(0, 0, 256, 256);

      // Five-point star, softly blurred edges
      g.save();
      g.translate(128, 128);
      g.rotate(-Math.PI / 2);
      g.beginPath();
      const R = 44;
      const r = 19;
      for (let i = 0; i < 10; i++) {
        const rad = i % 2 === 0 ? R : r;
        const a = (i * Math.PI) / 5;
        g[i === 0 ? 'moveTo' : 'lineTo'](Math.cos(a) * rad, Math.sin(a) * rad);
      }
      g.closePath();
      g.shadowColor = 'rgba(245, 236, 216, 0.9)';
      g.shadowBlur = 18;
      g.fillStyle = CREAM;
      g.fill();
      g.restore();

      const tex = new THREE.CanvasTexture(c);
      tex.anisotropy = 4;
      return tex;
    }

    // Aurora ribbon: horizontal chalky streaks with soft falloff
    function auroraTexture(hex: string, seed: string) {
      const c = document.createElement('canvas');
      c.width = 512;
      c.height = 256;
      const g = c.getContext('2d')!;
      const r = hash(seed);
      for (let band = 0; band < 5; band++) {
        const yC = 40 + r() * 176;
        const thick = 14 + r() * 34;
        const grad = g.createLinearGradient(0, yC - thick, 0, yC + thick);
        grad.addColorStop(0, hex + '00');
        grad.addColorStop(0.5, hex + (band === 0 ? '2e' : '1c'));
        grad.addColorStop(1, hex + '00');
        g.fillStyle = grad;
        g.beginPath();
        g.moveTo(0, yC);
        for (let x = 0; x <= 512; x += 16) {
          g.lineTo(x, yC + Math.sin(x * 0.012 + r() * 6) * 18 - thick);
        }
        for (let x = 512; x >= 0; x -= 16) {
          g.lineTo(x, yC + Math.sin(x * 0.011 + r() * 6) * 18 + thick);
        }
        g.closePath();
        g.fill();
      }
      return new THREE.CanvasTexture(c);
    }

    function plaqueTexture(post: FlightPost) {
      const c = document.createElement('canvas');
      c.width = 1024;
      c.height = 224;
      const g = c.getContext('2d')!;
      g.textAlign = 'center';
      g.fillStyle = INK;
      let size = 54;
      g.font = `500 ${size}px Fraunces, Georgia, serif`;
      while (g.measureText(post.title).width > 940 && size > 30) {
        size -= 3;
        g.font = `500 ${size}px Fraunces, Georgia, serif`;
      }
      if (g.measureText(post.title).width > 940) {
        const words = post.title.split(' ');
        let l1 = '';
        let l2 = '';
        for (const w of words) {
          if (g.measureText(l1 + ' ' + w).width < 860 && !l2) l1 = (l1 + ' ' + w).trim();
          else l2 = (l2 + ' ' + w).trim();
        }
        g.fillText(l1, 512, 84);
        g.fillText(l2, 512, 84 + size * 1.15);
      } else {
        g.fillText(post.title, 512, 104);
      }
      g.font = '400 25px "Space Mono", monospace';
      g.fillStyle = GOLD;
      g.fillText(`${post.dateLabel}  ✦  ${tagLabel(post.tag).toUpperCase()}`, 512, 192);
      const tex = new THREE.CanvasTexture(c);
      tex.anisotropy = 4;
      return tex;
    }

    // Big faint spaced-out year marker, NatGeo-diagram style
    function yearTexture(year: number) {
      const c = document.createElement('canvas');
      c.width = 1024;
      c.height = 256;
      const g = c.getContext('2d')!;
      g.textAlign = 'center';
      g.font = '700 150px "Space Mono", monospace';
      g.fillStyle = 'rgba(236, 234, 227, 0.85)';
      const spaced = String(year).split('').join(' ');
      g.fillText(spaced, 512, 180);
      return new THREE.CanvasTexture(c);
    }

    /* ---------- Starfield: dense chalky speckle ---------- */
    const STAR_COUNT = 3200;
    const rand = hash('the-long-way-sideways');
    const sPos = new Float32Array(STAR_COUNT * 3);
    const sSize = new Float32Array(STAR_COUNT);
    const sPhase = new Float32Array(STAR_COUNT);
    const sSpeed = new Float32Array(STAR_COUNT);

    for (let i = 0; i < STAR_COUNT; i++) {
      sPos[i * 3] = -200 + rand() * (xWell + 600);
      sPos[i * 3 + 1] = -260 + rand() * 520;
      sPos[i * 3 + 2] = 60 - rand() * 480;
      sSize[i] = 0.5 + rand() * 1.7;
      sPhase[i] = rand();
      sSpeed[i] = 0.2 + rand() * 1.0;
    }

    const starGeo = new THREE.BufferGeometry();
    starGeo.setAttribute('position', new THREE.BufferAttribute(sPos, 3));
    starGeo.setAttribute('aSize', new THREE.BufferAttribute(sSize, 1));
    starGeo.setAttribute('aPhase', new THREE.BufferAttribute(sPhase, 1));
    starGeo.setAttribute('aSpeed', new THREE.BufferAttribute(sSpeed, 1));

    const starMat = new THREE.ShaderMaterial({
      transparent: true,
      depthWrite: false,
      uniforms: {
        uTime: { value: 0 },
        uPx: { value: Math.min(devicePixelRatio, dprCap) },
      },
      vertexShader: `
        attribute float aSize;
        attribute float aPhase;
        attribute float aSpeed;
        varying float vPhase;
        varying float vSpeed;
        uniform float uPx;
        void main() {
          vPhase = aPhase;
          vSpeed = aSpeed;
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          gl_PointSize = clamp(aSize * uPx * (170.0 / -mv.z), 0.0, 6.0);
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        uniform float uTime;
        varying float vPhase;
        varying float vSpeed;
        void main() {
          float d = distance(gl_PointCoord, vec2(0.5));
          float core = smoothstep(0.5, 0.08, d);
          float tw = 0.6 + 0.4 * sin(uTime * vSpeed + vPhase * 6.28318);
          vec3 warm = vec3(0.93, 0.91, 0.86);
          vec3 lav = vec3(0.78, 0.75, 0.88);
          vec3 col = mix(warm, lav, step(0.6, fract(vPhase * 7.31)));
          gl_FragColor = vec4(col, core * tw * 0.7);
        }
      `,
    });
    scene.add(new THREE.Points(starGeo, starMat));

    /* ---------- Aurora veils, far background ---------- */
    const aRand = hash('aurora-veils');
    const auroraHues = [AURORA_TEAL, AURORA_LAVENDER, AURORA_TEAL, AURORA_LAVENDER, AURORA_TEAL];
    const auroras: THREE.Sprite[] = [];
    for (let i = 0; i < 5; i++) {
      const mat = new THREE.SpriteMaterial({
        map: auroraTexture(auroraHues[i], 'veil-' + i),
        transparent: true,
        opacity: 0.5,
        depthWrite: false,
      });
      const s = new THREE.Sprite(mat);
      const x = (i / 4) * (xWell + 200) - 60 + (aRand() - 0.5) * 120;
      s.position.set(x, 30 + (aRand() - 0.5) * 120, -300 - aRand() * 120);
      s.scale.set(720 + aRand() * 260, 340 + aRand() * 120, 1);
      scene.add(s);
      auroras.push(s);
    }

    /* ---------- The spacetime line + gold light-line ---------- */
    const linePts: THREE.Vector3[] = [];
    for (let x = -160; x <= xWell + 320; x += 4) {
      linePts.push(new THREE.Vector3(x, lineY(x), 0));
    }
    const spaceLine = new THREE.Line(
      new THREE.BufferGeometry().setFromPoints(linePts),
      new THREE.LineBasicMaterial({ color: 0xcfd0dc, transparent: true, opacity: 0.34 })
    );
    scene.add(spaceLine);

    const goldPts: THREE.Vector3[] = [];
    for (let x = -160; x <= xWell + 40; x += 4) {
      goldPts.push(new THREE.Vector3(x, lineY(x) + 3.2, 0.5));
    }
    const goldGeo = new THREE.BufferGeometry().setFromPoints(goldPts);
    const goldLine = new THREE.Line(
      goldGeo,
      new THREE.LineDashedMaterial({
        color: 0xd9a94f,
        transparent: true,
        opacity: 0.55,
        dashSize: 6,
        gapSize: 7,
      })
    );
    goldLine.computeLineDistances();
    goldLine.geometry.setDrawRange(0, 0);
    scene.add(goldLine);
    const goldTotal = goldPts.length;

    /* ---------- Post stars, shimmering on the sides ---------- */
    const starTex = postStarTexture();
    const starSprites: THREE.Sprite[] = [];
    const starPos: THREE.Vector3[] = [];
    const starBaseScale: number[] = [];
    const starBoost: number[] = posts.map(() => 0);

    const constellationPts: THREE.Vector3[] = [];

    posts.forEach((post, i) => {
      const r = hash(post.slug);
      const side = i % 2 === 0 ? 1 : -1;
      const x = X_FIRST + i * STEP;
      const y = baseY(x) + side * (46 + r() * 18);
      const z = (r() - 0.5) * 40;

      const mat = new THREE.SpriteMaterial({
        map: starTex,
        transparent: true,
        opacity: 0.92,
        depthWrite: false,
      });
      const star = new THREE.Sprite(mat);
      star.position.set(x, y, z);
      const sc = 17 + r() * 4;
      star.scale.set(sc, sc, 1);
      star.userData.index = i;
      scene.add(star);
      starSprites.push(star);
      starPos.push(star.position.clone());
      starBaseScale.push(sc);
      constellationPts.push(star.position.clone());

      const plaque = new THREE.Mesh(
        new THREE.PlaneGeometry(34, 34 * (224 / 1024)),
        new THREE.MeshBasicMaterial({
          map: plaqueTexture(post),
          transparent: true,
          opacity: 0.92,
          depthWrite: false,
        })
      );
      plaque.position.set(x, y - sc * 0.72 - 5.4, z);
      scene.add(plaque);
    });

    // Chalky constellation thread linking the stars
    const thread = new THREE.Line(
      new THREE.BufferGeometry().setFromPoints(constellationPts),
      new THREE.LineBasicMaterial({ color: 0xdad7cc, transparent: true, opacity: 0.14 })
    );
    scene.add(thread);

    /* ---------- Year markers drifting past in the background ---------- */
    let prevYear = -1;
    posts.forEach((post, i) => {
      if (post.year === prevYear) return;
      prevYear = post.year;
      const mat = new THREE.SpriteMaterial({
        map: yearTexture(post.year),
        transparent: true,
        opacity: 0.07,
        depthWrite: false,
      });
      const s = new THREE.Sprite(mat);
      s.position.set(X_FIRST + i * STEP - 40, 68, -170);
      s.scale.set(190, 47, 1);
      scene.add(s);
    });

    /* ---------- The dark star at the bottom of the well ---------- */
    const wellDepthY = lineY(xWell);
    const holeGroup = new THREE.Group();
    holeGroup.position.set(xWell, wellDepthY + 10, 0);
    scene.add(holeGroup);

    // Warm halo (the inverse of a post star: dark heart, warm rim)
    const halo = new THREE.Sprite(
      new THREE.SpriteMaterial({
        map: radialGlowTexture('rgba(232, 168, 107, 0.5)', 'rgba(232, 168, 107, 0)'),
        transparent: true,
        opacity: 0.85,
        depthWrite: false,
      })
    );
    halo.scale.set(120, 120, 1);
    scene.add(holeGroup);
    holeGroup.add(halo);

    const dark = new THREE.Sprite(
      new THREE.SpriteMaterial({
        map: radialGlowTexture('rgba(8, 8, 16, 1)', 'rgba(8, 8, 16, 0)', 0.45),
        transparent: true,
        opacity: 1,
        depthWrite: false,
      })
    );
    dark.scale.set(46, 46, 1);
    dark.position.z = 1;
    holeGroup.add(dark);

    // Slow chalky swirl of captured starlight
    const SPIRAL_N = 260;
    const spPos = new Float32Array(SPIRAL_N * 3);
    const spSize = new Float32Array(SPIRAL_N);
    const spPhase = new Float32Array(SPIRAL_N);
    const spSpeed = new Float32Array(SPIRAL_N);
    const spRand = hash('the-pull');
    for (let i = 0; i < SPIRAL_N; i++) {
      const t = spRand();
      const arm = spRand() < 0.5 ? 0 : Math.PI;
      const theta = arm + t * 4.2 + spRand() * 0.5;
      const rad = 16 + t * 78;
      spPos[i * 3] = Math.cos(theta) * rad;
      spPos[i * 3 + 1] = Math.sin(theta) * rad * 0.55;
      spPos[i * 3 + 2] = (spRand() - 0.5) * 10;
      spSize[i] = 0.5 + spRand() * 1.4;
      spPhase[i] = spRand();
      spSpeed[i] = 0.4 + spRand() * 1.2;
    }
    const spGeo = new THREE.BufferGeometry();
    spGeo.setAttribute('position', new THREE.BufferAttribute(spPos, 3));
    spGeo.setAttribute('aSize', new THREE.BufferAttribute(spSize, 1));
    spGeo.setAttribute('aPhase', new THREE.BufferAttribute(spPhase, 1));
    spGeo.setAttribute('aSpeed', new THREE.BufferAttribute(spSpeed, 1));
    const spiral = new THREE.Points(spGeo, starMat.clone());
    holeGroup.add(spiral);

    /* ---------- Camera + interaction state ---------- */
    let progress = 0; // eased
    let mouseX = 0;
    let mouseY = 0;
    let lookX = 0;
    let lookY = 0;
    let hovered = -1;
    let focused = -1;
    let focusT = 0; // 0 = drifting, 1 = at star
    let running = false;
    let flying = false;
    let hintGone = false;
    let ended = false;

    const railPos = new THREE.Vector3();
    const focusPos = new THREE.Vector3();
    const railQuat = new THREE.Quaternion();
    const focusQuat = new THREE.Quaternion();
    // Must be a camera: Object3D.lookAt points +Z at the target, cameras view down -Z
    const dummy = new THREE.PerspectiveCamera();
    const raycaster = new THREE.Raycaster();
    const pointer = new THREE.Vector2(-10, -10);

    window.addEventListener(
      'pointermove',
      (e) => {
        pointer.x = (e.clientX / innerWidth) * 2 - 1;
        pointer.y = -(e.clientY / innerHeight) * 2 + 1;
        mouseX = pointer.x;
        mouseY = pointer.y;
      },
      { passive: true }
    );

    /* ---------- Audio ---------- */
    let audio: ReturnType<typeof makeAudio> | null = null;
    let muted = false;

    muteBtn.addEventListener('click', () => {
      muted = !muted;
      audio?.setMuted(muted);
      muteBtn.textContent = muted ? 'SOUND OFF' : 'SOUND ON';
    });

    /* ---------- Font preload, then arm the launch button ---------- */
    const dbg: Record<string, boolean> = ((window as any).__saDebug = {
      fonts: false,
      armed: false,
    });

    function armLaunch() {
      if (dbg.armed) return;
      dbg.armed = true;
      gateLaunch.disabled = false;
      gateLaunch.textContent = 'Launch';
    }

    Promise.resolve((document as any).fonts?.ready).then(() => {
      dbg.fonts = true;
      armLaunch();
    });
    // Never strand the visitor on a stuck preload
    setTimeout(armLaunch, 5000);

    /* ---------- Flight mode on/off ---------- */
    const lenis = () => (window as any).__lenis;

    function enterFlight() {
      flying = true;
      document.body.classList.add('flying');
      flatSection.style.display = 'none';
      track.style.height = `${posts.length * 55 + 280}vh`;
      window.scrollTo(0, 0);
      lenis()?.scrollTo(0, { immediate: true });
      gate.classList.add('leaving');
      setTimeout(() => {
        gate.classList.remove('show', 'leaving');
        gate.setAttribute('aria-hidden', 'true');
      }, 900);
      canvas.classList.add('is-on');
      if (!audio) audio = makeAudio();
      audio.ctx.resume();
      audio.setMuted(muted);
      if (!running) {
        running = true;
        requestAnimationFrame(frame);
      }
    }

    function exitFlight() {
      flying = false;
      running = false;
      closeFocus(true);
      document.body.classList.remove('flying');
      canvas.classList.remove('is-on');
      flatSection.style.display = '';
      track.style.height = '0';
      endCard.classList.remove('show');
      ended = false;
      audio?.setMuted(true);
      window.scrollTo(0, 0);
      lenis()?.scrollTo(0, { immediate: true });
    }

    gateLaunch.addEventListener('click', enterFlight);
    relaunch.addEventListener('click', enterFlight);
    gateSkip.addEventListener('click', () => {
      gate.classList.add('leaving');
      setTimeout(() => {
        gate.classList.remove('show', 'leaving');
        gate.setAttribute('aria-hidden', 'true');
      }, 900);
    });
    exitBtn.addEventListener('click', exitFlight);
    endFlat.addEventListener('click', exitFlight);
    returnLaunch.addEventListener('click', () => {
      lenis()?.scrollTo(0, { duration: 3 });
    });

    /* ---------- Star focus ---------- */
    function openFocus(i: number) {
      if (focused === i) return;
      focused = i;
      const post = posts[i];
      focusMeta.textContent = `${tagLabel(post.tag)} ✦ ${post.category}`;
      focusTitle.textContent = post.title;
      focusDate.textContent = post.dateLabel;
      focusDesc.textContent = post.description;
      focusRead.href = `/post/${post.slug}`;
      focusCard.classList.add('show');
      focusCard.setAttribute('aria-hidden', 'false');
      lenis()?.stop();
      gsap.to({ v: focusT }, {
        v: 1,
        duration: 1.3,
        ease: 'power3.inOut',
        onUpdate() {
          focusT = (this.targets()[0] as any).v;
        },
      });
    }

    function closeFocus(instant = false) {
      if (focused === -1) return;
      focused = -1;
      focusCard.classList.remove('show');
      focusCard.setAttribute('aria-hidden', 'true');
      lenis()?.start();
      if (instant) {
        focusT = 0;
        return;
      }
      gsap.to({ v: focusT }, {
        v: 0,
        duration: 1.0,
        ease: 'power3.inOut',
        onUpdate() {
          focusT = (this.targets()[0] as any).v;
        },
      });
    }

    focusClose.addEventListener('click', () => closeFocus());
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeFocus();
    });

    canvas.addEventListener('click', () => {
      if (!flying) return;
      if (focused !== -1) {
        closeFocus();
        return;
      }
      if (hovered >= 0) openFocus(hovered);
    });

    /* ---------- HUD ---------- */
    function updateHud(camX: number, p: number) {
      hudGaugeFill.style.height = `${Math.round(p * 100)}%`;
      let nearest = -1;
      let best = Infinity;
      for (let i = 0; i < starPos.length; i++) {
        const d = Math.abs(camX - starPos[i].x);
        if (d < best) {
          best = d;
          nearest = i;
        }
      }
      if (nearest >= 0 && best < 200) {
        const post = posts[nearest];
        hudSector.textContent = `TRANSMISSION ${String(nearest + 1).padStart(2, '0')}/${posts.length} · SECTOR ${post.year}`;
      } else if (camX > xLast + 120) {
        hudSector.textContent = 'APPROACHING EVENT HORIZON';
      } else {
        hudSector.textContent = 'DEEP SPACE';
      }
    }

    /* ---------- Frame loop ---------- */
    const t0 = performance.now();
    const tNow = () => (performance.now() - t0) / 1000;
    let hudTick = 0;

    function frame() {
      if (!running) return;
      const t = tNow();

      // Scroll → progress (Lenis already smooths the scroll itself).
      // Frozen while a star is in focus so nothing can yank the camera mid-read.
      if (focused === -1) {
        const scrollable = Math.max(1, document.documentElement.scrollHeight - innerHeight);
        const target = Math.min(1, Math.max(0, scrollY / scrollable));
        progress += (target - progress) * 0.06;
      }

      if (!hintGone && scrollY > 60) {
        hintGone = true;
        hudHint.classList.add('gone');
      }

      const camX = X_START + (X_END - X_START) * progress;

      // Final descent: as the well approaches, sink with the line
      const sink = Math.min(1, Math.max(0, (camX - (xWell - 420)) / 340));
      const sinkEase = sink * sink * (3 - 2 * sink);
      const camY = -4 - sinkEase * 88;
      const lookYBase = -16 - sinkEase * 118;

      // Rail pose — eased mouse-look, gentle vertical breath
      lookX += (mouseX - lookX) * 0.06;
      lookY += (mouseY - lookY) * 0.06;
      const breathe = Math.sin(t * 0.4) * 1.6;
      railPos.set(camX, camY + breathe * 0.4, CAM_DIST);
      dummy.position.copy(railPos);
      dummy.lookAt(camX + 14 + lookX * 18, lookYBase + breathe + lookY * 12, 0);
      railQuat.copy(dummy.quaternion);

      // Focus pose (drift toward the focused star)
      if (focused !== -1 || focusT > 0.001) {
        const i = focused !== -1 ? focused : Math.max(0, hovered);
        const sp = starPos[Math.min(i, starPos.length - 1)];
        focusPos.set(sp.x - 6, sp.y + 1, sp.z + 52);
        dummy.position.copy(focusPos);
        dummy.lookAt(sp.x, sp.y, sp.z);
        focusQuat.copy(dummy.quaternion);
        camera.position.lerpVectors(railPos, focusPos, focusT);
        camera.quaternion.slerpQuaternions(railQuat, focusQuat, focusT);
      } else {
        camera.position.copy(railPos);
        camera.quaternion.copy(railQuat);
      }

      // Uniforms + ambient motion
      starMat.uniforms.uTime.value = t;
      (spiral.material as THREE.ShaderMaterial).uniforms.uTime.value = t;
      spiral.rotation.z = t * 0.04;
      auroras.forEach((a, i) => {
        a.position.y += Math.sin(t * 0.05 + i * 1.7) * 0.012;
        (a.material as THREE.SpriteMaterial).opacity = 0.42 + 0.1 * Math.sin(t * 0.08 + i * 2.1);
      });

      // The gold light-line draws itself as you travel
      const goldN = Math.floor(((camX + 160 + 60) / (xWell + 40 + 160)) * goldTotal);
      goldLine.geometry.setDrawRange(0, Math.max(0, Math.min(goldTotal, goldN)));

      // Hover raycast (only while drifting)
      let hit = -1;
      if (focused === -1 && focusT < 0.05) {
        raycaster.setFromCamera(pointer, camera);
        const hits = raycaster.intersectObjects(starSprites, false);
        if (hits.length) hit = hits[0].object.userData.index;
      }
      if (hit !== hovered) {
        hovered = hit;
        document.body.style.cursor = hit >= 0 ? 'pointer' : '';
      }

      // Star shimmer + hover swell
      for (let i = 0; i < starSprites.length; i++) {
        const want = i === hovered || i === focused ? 1 : 0;
        starBoost[i] += (want - starBoost[i]) * 0.1;
        const shimmer = 1 + 0.05 * Math.sin(t * 1.3 + i * 2.3);
        const sc = starBaseScale[i] * shimmer * (1 + starBoost[i] * 0.35);
        starSprites[i].scale.set(sc, sc, 1);
        (starSprites[i].material as THREE.SpriteMaterial).opacity =
          0.82 + 0.1 * Math.sin(t * 1.1 + i * 1.7) + starBoost[i] * 0.15;
      }

      // End card
      if (progress > 0.985 && !ended) {
        ended = true;
        endCard.classList.add('show');
        endCard.setAttribute('aria-hidden', 'false');
      } else if (progress < 0.96 && ended) {
        ended = false;
        endCard.classList.remove('show');
        endCard.setAttribute('aria-hidden', 'true');
      }

      // HUD every few frames
      if (++hudTick % 8 === 0) updateHud(camX, progress);

      renderer.render(scene, camera);
      requestAnimationFrame(frame);
    }

    /* ---------- Housekeeping ---------- */
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        running = false;
      } else if (flying && !running) {
        running = true;
        requestAnimationFrame(frame);
      }
    });

    window.addEventListener('resize', () => {
      camera.aspect = innerWidth / innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(innerWidth, innerHeight);
      renderer.setPixelRatio(Math.min(devicePixelRatio, dprCap));
    });

    // Dev introspection hook (harmless in production)
    (window as any).__sa = { scene, camera, renderer, starPos, starSprites };
  }

  // Called last so every const above is initialised before init touches it.
  if (eligible) {
    try {
      init();
    } catch (err) {
      // Surface init failures where we can see them (console capture can miss module errors)
      gateLaunch.textContent = 'INIT ERR: ' + (err as Error).message;
      console.error('[space-archive]', err);
    }
  }
</script>
