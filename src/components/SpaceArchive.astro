---
/*
  The Space Archive — a rail flight through the back catalogue.
  Scroll flies you along a drifting path; every post is a glowing portal,
  newest near the launch point, oldest deepest — all of it falling toward
  a black hole at the end of the line.

  Desktop + fine-motion only: phones and prefers-reduced-motion visitors
  stay on the flat list rendered by archive.astro. No JS = flat list.
*/
interface FlightPost {
  title: string;
  slug: string;
  category: string;
  tag: string;
  description: string;
  image: string;
  year: number;
  dateLabel: string;
}

interface Props {
  posts: FlightPost[];
  range: string;
}

const { posts, range } = Astro.props;
---

<script type="application/json" id="flight-data" set:html={JSON.stringify(posts)} />

<!-- Scroll track: gives the document its flight length while flying -->
<div class="flight-track" id="flight-track" aria-hidden="true"></div>

<canvas class="flight-canvas" id="flight-canvas" aria-hidden="true"></canvas>

<!-- Visor -->
<div class="visor" id="visor" aria-hidden="true">
  <div class="visor-edge visor-edge-l"></div>
  <div class="visor-edge visor-edge-r"></div>
  <div class="visor-vignette"></div>
</div>

<!-- HUD -->
<div class="hud" id="hud" aria-hidden="true">
  <div class="hud-readout">
    <span class="hud-line hud-title">✦ THE ARCHIVE</span>
    <span class="hud-line" id="hud-sector">CALIBRATING…</span>
  </div>
  <div class="hud-gauge">
    <div class="hud-gauge-fill" id="hud-gauge-fill"></div>
    <span class="hud-gauge-label hud-gauge-now">NOW</span>
    <span class="hud-gauge-label hud-gauge-horizon">EVENT HORIZON</span>
  </div>
  <div class="hud-hint" id="hud-hint">SCROLL TO FLY · CLICK A PORTAL TO INSPECT</div>
  <div class="hud-controls">
    <button class="hud-btn" id="mute-btn" type="button" aria-label="Toggle sound">SOUND ON</button>
    <button class="hud-btn" id="exit-flight" type="button">FLAT VIEW</button>
  </div>
</div>

<!-- Portal preview card -->
<aside class="focus-card" id="focus-card" aria-hidden="true">
  <button class="focus-close" id="focus-close" type="button" aria-label="Close preview">×</button>
  <span class="focus-meta eyebrow" id="focus-meta"></span>
  <h3 class="focus-title" id="focus-title"></h3>
  <span class="focus-date" id="focus-date"></span>
  <p class="focus-desc" id="focus-desc"></p>
  <a class="btn focus-read" id="focus-read" href="/">Read the transmission</a>
</aside>

<!-- End of the line -->
<div class="end-card" id="end-card" aria-hidden="true">
  <span class="eyebrow">✦ END OF TRANSMISSION</span>
  <h3 class="end-title">You've reached the <em>event horizon</em></h3>
  <p class="end-copy">Nothing older survives past this point. Everything else has already fallen in.</p>
  <div class="end-actions">
    <button class="hud-btn" id="return-launch" type="button">RETURN TO LAUNCH</button>
    <button class="hud-btn" id="end-flat" type="button">FLAT VIEW</button>
  </div>
</div>

<!-- Launch gate -->
<div class="gate" id="gate" aria-hidden="true">
  <span class="eyebrow gate-eyebrow">✦ DAMIEN.HERLIHY PRESENTS</span>
  <h2 class="gate-title">The <em>Archive</em></h2>
  <p class="gate-sub">
    {posts.length} transmissions · {range} · drifting toward the event horizon
  </p>
  <button class="btn gate-launch" id="gate-launch" type="button" disabled>Calibrating…</button>
  <button class="gate-skip" id="gate-skip" type="button">or browse the flat archive</button>
  <span class="gate-hint">SCROLL TO FLY · MOUSE TO LOOK · CLICK A PORTAL TO INSPECT</span>
</div>

<style>
  .flight-track {
    display: none;
    width: 1px;
  }

  .flight-canvas {
    display: none;
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    opacity: 0;
    transition: opacity 1.6s ease;
  }

  body.flying .flight-track {
    display: block;
  }

  body.flying .flight-canvas {
    display: block;
  }

  .flight-canvas.is-on {
    opacity: 1;
  }

  /* ===== Gate ===== */
  .gate {
    position: fixed;
    inset: 0;
    z-index: 500;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 18px;
    text-align: center;
    padding: 24px;
    background:
      radial-gradient(ellipse 70% 55% at 50% 42%, rgba(217, 169, 79, 0.07), transparent 70%),
      var(--bg-deep);
    opacity: 0;
    transition: opacity 0.9s ease;
  }

  .gate.show {
    display: flex;
    opacity: 1;
  }

  .gate.leaving {
    opacity: 0;
    pointer-events: none;
  }

  .gate-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(52px, 9vw, 110px);
    line-height: 1.02;
    color: var(--ink);
    margin: 0;
  }

  .gate-title em {
    font-style: italic;
    color: var(--gold);
  }

  .gate-sub {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin: 0 0 14px;
  }

  .gate-launch {
    min-width: 220px;
    justify-content: center;
  }

  .gate-skip {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--ink-faint);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.3s var(--ease);
  }

  .gate-skip:hover {
    color: var(--ink);
  }

  .gate-hint {
    position: absolute;
    bottom: 34px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--ink-faint);
  }

  /* ===== Visor ===== */
  .visor {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 80;
    pointer-events: none;
  }

  body.flying .visor {
    display: block;
  }

  .visor-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 92% 88% at 50% 50%, transparent 62%, rgba(4, 4, 8, 0.55) 100%);
  }

  .visor-edge {
    position: absolute;
    top: -12vh;
    bottom: -12vh;
    width: 22vw;
    border: 1px solid rgba(236, 234, 227, 0.05);
  }

  .visor-edge-l {
    left: -14vw;
    border-radius: 0 50% 50% 0;
    background: linear-gradient(to right, rgba(8, 8, 13, 0.5), transparent 70%);
  }

  .visor-edge-r {
    right: -14vw;
    border-radius: 50% 0 0 50%;
    background: linear-gradient(to left, rgba(8, 8, 13, 0.5), transparent 70%);
  }

  /* ===== HUD ===== */
  .hud {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 90;
    pointer-events: none;
  }

  body.flying .hud {
    display: block;
  }

  .hud-readout {
    position: absolute;
    left: clamp(20px, 4vw, 48px);
    top: 96px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .hud-line {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--ink-faint);
  }

  .hud-title {
    color: var(--gold);
  }

  .hud-gauge {
    position: absolute;
    right: clamp(20px, 3vw, 40px);
    top: 50%;
    transform: translateY(-50%);
    width: 2px;
    height: 34vh;
    background: var(--hairline);
  }

  .hud-gauge-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: var(--gold);
    box-shadow: 0 0 8px var(--gold-glow);
  }

  .hud-gauge-label {
    position: absolute;
    right: 10px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .hud-gauge-now {
    top: -4px;
  }

  .hud-gauge-horizon {
    bottom: -4px;
  }

  .hud-hint {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--ink-faint);
    transition: opacity 1s ease;
  }

  .hud-hint.gone {
    opacity: 0;
  }

  .hud-controls {
    position: absolute;
    right: clamp(20px, 3vw, 40px);
    bottom: 26px;
    display: flex;
    gap: 10px;
    pointer-events: auto;
  }

  .hud-btn {
    pointer-events: auto;
    background: rgba(8, 8, 13, 0.6);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--hairline-strong);
    border-radius: 999px;
    padding: 9px 16px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--ink-dim);
    cursor: pointer;
    transition:
      color 0.3s var(--ease),
      border-color 0.3s var(--ease);
  }

  .hud-btn:hover {
    color: var(--gold-bright);
    border-color: var(--gold-dim);
  }

  /* ===== Focus card ===== */
  .focus-card {
    position: fixed;
    z-index: 120;
    top: 50%;
    right: clamp(24px, 7vw, 110px);
    transform: translateY(-50%) translateX(24px);
    width: min(400px, 84vw);
    padding: 30px 30px 28px;
    background: rgba(8, 8, 13, 0.78);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid var(--hairline-strong);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.5s var(--ease),
      transform 0.5s var(--ease);
  }

  .focus-card.show {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(-50%) translateX(0);
  }

  .focus-close {
    position: absolute;
    top: 12px;
    right: 16px;
    background: none;
    border: none;
    color: var(--ink-faint);
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    transition: color 0.3s var(--ease);
  }

  .focus-close:hover {
    color: var(--ink);
  }

  .focus-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(22px, 2.4vw, 30px);
    line-height: 1.2;
    color: var(--ink);
    margin: 0;
  }

  .focus-date {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--ink-faint);
  }

  .focus-desc {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-dim);
    margin: 0;
  }

  .focus-read {
    align-self: flex-start;
    margin-top: 6px;
  }

  /* ===== End card ===== */
  .end-card {
    position: fixed;
    z-index: 110;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -46%);
    width: min(520px, 88vw);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding: 40px 34px;
    background: rgba(8, 8, 13, 0.7);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--hairline-strong);
    border-radius: 18px;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.8s var(--ease),
      transform 0.8s var(--ease);
  }

  .end-card.show {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, -50%);
  }

  .end-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(26px, 3.4vw, 38px);
    line-height: 1.15;
    color: var(--ink);
    margin: 0;
  }

  .end-title em {
    font-style: italic;
    color: var(--gold);
  }

  .end-copy {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--ink-dim);
    margin: 0 0 8px;
  }

  .end-actions {
    display: flex;
    gap: 10px;
  }

  /* Hide footer + noise while flying; the void needs no grain */
  :global(body.flying footer) {
    display: none;
  }

  /* No-JS never sees any of this */
  :global(html:not(.js)) .gate,
  :global(html:not(.js)) .flight-canvas {
    display: none !important;
  }
</style>

<script>
  import * as THREE from 'three';
  import gsap from 'gsap';

  interface FlightPost {
    title: string;
    slug: string;
    category: string;
    tag: string;
    description: string;
    image: string;
    year: number;
    dateLabel: string;
  }

  const posts: FlightPost[] = JSON.parse(
    document.getElementById('flight-data')!.textContent || '[]'
  );

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const bigScreen = window.matchMedia('(min-width: 900px)').matches;

  const canvas = document.getElementById('flight-canvas') as HTMLCanvasElement;
  const gate = document.getElementById('gate')!;
  const gateLaunch = document.getElementById('gate-launch') as HTMLButtonElement;
  const gateSkip = document.getElementById('gate-skip')!;
  const track = document.getElementById('flight-track')!;
  const hudSector = document.getElementById('hud-sector')!;
  const hudGaugeFill = document.getElementById('hud-gauge-fill')!;
  const hudHint = document.getElementById('hud-hint')!;
  const muteBtn = document.getElementById('mute-btn')!;
  const exitBtn = document.getElementById('exit-flight')!;
  const focusCard = document.getElementById('focus-card')!;
  const focusClose = document.getElementById('focus-close')!;
  const focusMeta = document.getElementById('focus-meta')!;
  const focusTitle = document.getElementById('focus-title')!;
  const focusDate = document.getElementById('focus-date')!;
  const focusDesc = document.getElementById('focus-desc')!;
  const focusRead = document.getElementById('focus-read') as HTMLAnchorElement;
  const endCard = document.getElementById('end-card')!;
  const returnLaunch = document.getElementById('return-launch')!;
  const endFlat = document.getElementById('end-flat')!;
  const invite = document.getElementById('flight-invite')!;
  const relaunch = document.getElementById('relaunch-flight')!;
  const flatSection = document.getElementById('flat-archive')!;

  function webglOk() {
    try {
      const c = document.createElement('canvas');
      return !!(c.getContext('webgl2') || c.getContext('webgl'));
    } catch {
      return false;
    }
  }

  const eligible = !reducedMotion && bigScreen && posts.length > 0 && webglOk();

  function tagLabel(tag: string) {
    if (tag.startsWith('Galaxy')) return 'Essay';
    if (tag.startsWith('Star')) return 'Note';
    if (tag.startsWith('Constellation')) return 'Pattern';
    return 'Library';
  }

  const CATEGORY_COLORS: Record<string, string> = {
    'AI & Teaching': '#d9a94f',
    'Personal Knowledge Mgt': '#7f9bff',
    'Second Mountain': '#e0899b',
    'Learning How to Learn': '#6fd3c7',
    Languages: '#b48ae0',
  };

  /* =========================================================
     Audio — synthesised, no files. Hum + portal chime.
     ========================================================= */
  function makeAudio() {
    const ctx = new AudioContext();
    const master = ctx.createGain();
    master.gain.value = 1;
    master.connect(ctx.destination);

    // Deep hum: filtered noise + low sine
    const noiseBuf = ctx.createBuffer(1, ctx.sampleRate * 2, ctx.sampleRate);
    const data = noiseBuf.getChannelData(0);
    let last = 0;
    for (let i = 0; i < data.length; i++) {
      const white = Math.random() * 2 - 1;
      last = (last + 0.02 * white) / 1.02; // brown-ish noise
      data[i] = last * 3.5;
    }
    const noise = ctx.createBufferSource();
    noise.buffer = noiseBuf;
    noise.loop = true;
    const lowpass = ctx.createBiquadFilter();
    lowpass.type = 'lowpass';
    lowpass.frequency.value = 110;
    const noiseGain = ctx.createGain();
    noiseGain.gain.value = 0.05;
    noise.connect(lowpass).connect(noiseGain).connect(master);
    noise.start();

    const drone = ctx.createOscillator();
    drone.type = 'sine';
    drone.frequency.value = 48;
    const droneGain = ctx.createGain();
    droneGain.gain.value = 0.028;
    drone.connect(droneGain).connect(master);
    drone.start();

    // Slow breathing on the filter
    const lfo = ctx.createOscillator();
    lfo.frequency.value = 0.06;
    const lfoGain = ctx.createGain();
    lfoGain.gain.value = 35;
    lfo.connect(lfoGain).connect(lowpass.frequency);
    lfo.start();

    function chime() {
      const t = ctx.currentTime;
      const osc = ctx.createOscillator();
      osc.type = 'sine';
      osc.frequency.setValueAtTime(660, t);
      osc.frequency.exponentialRampToValueAtTime(990, t + 0.18);
      const g = ctx.createGain();
      g.gain.setValueAtTime(0.0001, t);
      g.gain.exponentialRampToValueAtTime(0.07, t + 0.03);
      g.gain.exponentialRampToValueAtTime(0.0001, t + 1.4);
      osc.connect(g).connect(master);
      osc.start(t);
      osc.stop(t + 1.5);
    }

    return {
      ctx,
      chime,
      setMuted(m: boolean) {
        master.gain.linearRampToValueAtTime(m ? 0 : 1, ctx.currentTime + 0.3);
      },
    };
  }

  /* =========================================================
     The flight
     ========================================================= */
  function init() {
    gate.classList.add('show');
    gate.setAttribute('aria-hidden', 'false');
    invite.hidden = false;

    let renderer: THREE.WebGLRenderer;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
    } catch {
      gate.classList.remove('show');
      invite.hidden = true;
      return;
    }

    const dprCap = 2;
    renderer.setPixelRatio(Math.min(devicePixelRatio, dprCap));
    renderer.setSize(innerWidth, innerHeight);
    renderer.setClearColor(0x050508, 1);

    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x050508, 0.0028);

    const camera = new THREE.PerspectiveCamera(60, innerWidth / innerHeight, 0.1, 1400);

    /* ---------- Flight path ---------- */
    const SPACING = 130;
    const Z_FIRST = -180;
    const zHole = Z_FIRST - posts.length * SPACING - 240;
    const Z_END = zHole + 170; // camera stops here, staring into it
    const Z_START = 40;

    const pathX = (z: number) => Math.sin(z * 0.008) * 18;
    const pathY = (z: number) => Math.sin(z * 0.0047 + 1.7) * 7;

    /* ---------- Deterministic randomness ---------- */
    function hash(str: string) {
      let h = 2166136261;
      for (let i = 0; i < str.length; i++) {
        h ^= str.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return () => {
        h = Math.imul(h ^ (h >>> 15), 2246822507);
        h = Math.imul(h ^ (h >>> 13), 3266489909);
        return ((h ^= h >>> 16) >>> 0) / 4294967296;
      };
    }

    /* ---------- Starfield along the whole path ---------- */
    const STAR_COUNT = 2400;
    const rand = hash('the-long-way-down');
    const sPos = new Float32Array(STAR_COUNT * 3);
    const sSize = new Float32Array(STAR_COUNT);
    const sPhase = new Float32Array(STAR_COUNT);
    const sSpeed = new Float32Array(STAR_COUNT);

    for (let i = 0; i < STAR_COUNT; i++) {
      const z = 80 - rand() * (80 - (zHole - 500));
      sPos[i * 3] = pathX(z) + (rand() - 0.5) * 700;
      sPos[i * 3 + 1] = pathY(z) + (rand() - 0.5) * 500;
      sPos[i * 3 + 2] = z;
      sSize[i] = 0.7 + rand() * 2.1;
      sPhase[i] = rand();
      sSpeed[i] = 0.3 + rand() * 1.4;
    }

    const starGeo = new THREE.BufferGeometry();
    starGeo.setAttribute('position', new THREE.BufferAttribute(sPos, 3));
    starGeo.setAttribute('aSize', new THREE.BufferAttribute(sSize, 1));
    starGeo.setAttribute('aPhase', new THREE.BufferAttribute(sPhase, 1));
    starGeo.setAttribute('aSpeed', new THREE.BufferAttribute(sSpeed, 1));

    const starMat = new THREE.ShaderMaterial({
      transparent: true,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
      uniforms: {
        uTime: { value: 0 },
        uPx: { value: Math.min(devicePixelRatio, dprCap) },
      },
      vertexShader: `
        attribute float aSize;
        attribute float aPhase;
        attribute float aSpeed;
        varying float vPhase;
        varying float vSpeed;
        uniform float uPx;
        void main() {
          vPhase = aPhase;
          vSpeed = aSpeed;
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          gl_PointSize = clamp(aSize * uPx * (200.0 / -mv.z), 0.0, 7.0);
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        uniform float uTime;
        varying float vPhase;
        varying float vSpeed;
        void main() {
          float d = distance(gl_PointCoord, vec2(0.5));
          float core = smoothstep(0.5, 0.04, d);
          float tw = 0.55 + 0.45 * sin(uTime * vSpeed + vPhase * 6.28318);
          vec3 warm = vec3(0.93, 0.91, 0.86);
          vec3 cool = vec3(0.74, 0.78, 0.95);
          vec3 col = mix(warm, cool, step(0.55, fract(vPhase * 7.31)));
          gl_FragColor = vec4(col, core * tw * 0.85);
        }
      `,
    });
    scene.add(new THREE.Points(starGeo, starMat));

    /* ---------- Nebulae: soft colour along the way ---------- */
    function nebulaTexture(hex: string) {
      const c = document.createElement('canvas');
      c.width = c.height = 256;
      const g = c.getContext('2d')!;
      const grad = g.createRadialGradient(128, 128, 0, 128, 128, 128);
      grad.addColorStop(0, hex + '55');
      grad.addColorStop(0.5, hex + '18');
      grad.addColorStop(1, hex + '00');
      g.fillStyle = grad;
      g.fillRect(0, 0, 256, 256);
      return new THREE.CanvasTexture(c);
    }

    const nebulaHues = Object.values(CATEGORY_COLORS);
    const nRand = hash('nebulae');
    for (let i = 0; i < 6; i++) {
      const mat = new THREE.SpriteMaterial({
        map: nebulaTexture(nebulaHues[i % nebulaHues.length]),
        transparent: true,
        opacity: 0.4,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
      });
      const sprite = new THREE.Sprite(mat);
      const z = Z_FIRST - (i / 5.2) * (Z_FIRST - zHole) - 80;
      sprite.position.set(
        pathX(z) + (nRand() - 0.5) * 480,
        pathY(z) + (nRand() - 0.5) * 300,
        z - 160
      );
      const s = 420 + nRand() * 280;
      sprite.scale.set(s, s, 1);
      scene.add(sprite);
    }

    /* ---------- Portals ---------- */
    const texLoader = new THREE.TextureLoader();
    const ringMats: THREE.ShaderMaterial[] = [];
    const discMeshes: THREE.Mesh[] = [];
    const portalPos: THREE.Vector3[] = [];
    const chimed: boolean[] = posts.map(() => false);

    function coverFit(tex: THREE.Texture) {
      const img = tex.image as HTMLImageElement;
      const ia = img.width / img.height;
      if (ia > 1) {
        tex.repeat.set(1 / ia, 1);
        tex.offset.x = (1 - 1 / ia) / 2;
      } else {
        tex.repeat.set(1, ia);
        tex.offset.y = (1 - ia) / 2;
      }
    }

    function plaqueTexture(post: FlightPost, color: string) {
      const c = document.createElement('canvas');
      c.width = 1024;
      c.height = 224;
      const g = c.getContext('2d')!;
      g.textAlign = 'center';
      g.fillStyle = '#eceae3';
      let size = 58;
      g.font = `500 ${size}px Fraunces, Georgia, serif`;
      while (g.measureText(post.title).width > 960 && size > 30) {
        size -= 3;
        g.font = `500 ${size}px Fraunces, Georgia, serif`;
      }
      if (g.measureText(post.title).width > 960) {
        // Two lines
        const words = post.title.split(' ');
        let l1 = '';
        let l2 = '';
        for (const w of words) {
          if (g.measureText(l1 + ' ' + w).width < 880 && !l2) l1 = (l1 + ' ' + w).trim();
          else l2 = (l2 + ' ' + w).trim();
        }
        g.fillText(l1, 512, 86);
        g.fillText(l2, 512, 86 + size * 1.15);
      } else {
        g.fillText(post.title, 512, 108);
      }
      g.font = '400 26px "Space Mono", monospace';
      g.fillStyle = color;
      g.fillText(`${post.dateLabel}  ✦  ${tagLabel(post.tag).toUpperCase()}`, 512, 196);
      const tex = new THREE.CanvasTexture(c);
      tex.anisotropy = 4;
      return tex;
    }

    const ringShader = {
      vertexShader: `
        varying vec2 vUv;
        void main() {
          vUv = uv;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        uniform float uTime;
        uniform float uSeed;
        uniform float uBoost;
        varying vec2 vUv;
        void main() {
          vec2 p = vUv - 0.5;
          float r = length(p) * 2.0;
          float pulse = 0.82 + 0.18 * sin(uTime * 1.6 + uSeed);
          float band = smoothstep(0.10, 0.0, abs(r - 0.74));
          float halo = smoothstep(0.5, 0.0, abs(r - 0.74)) * 0.35;
          float a = (band + halo) * pulse * (0.75 + uBoost);
          gl_FragColor = vec4(uColor * (1.0 + uBoost * 0.6), a);
        }
      `,
    };

    const DISC_R = 11;

    posts.forEach((post, i) => {
      const r = hash(post.slug);
      const side = i % 2 === 0 ? 1 : -1;
      const z = Z_FIRST - i * SPACING;
      const x = pathX(z) + side * (27 + r() * 8);
      const y = pathY(z) + (r() - 0.5) * 10;
      const group = new THREE.Group();
      group.position.set(x, y, z);
      // Face the approaching flyer
      group.lookAt(pathX(z + 110), pathY(z + 110), z + 110);
      scene.add(group);
      portalPos.push(new THREE.Vector3(x, y, z));

      const color = new THREE.Color(CATEGORY_COLORS[post.category] || '#d9a94f');

      const ringMat = new THREE.ShaderMaterial({
        transparent: true,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
        uniforms: {
          uColor: { value: color },
          uTime: { value: 0 },
          uSeed: { value: r() * 6.28 },
          uBoost: { value: 0 },
        },
        ...ringShader,
      });
      ringMats.push(ringMat);
      const ring = new THREE.Mesh(new THREE.PlaneGeometry(DISC_R * 3.1, DISC_R * 3.1), ringMat);
      group.add(ring);

      const discMat = new THREE.MeshBasicMaterial({ color: 0x777777 });
      const disc = new THREE.Mesh(new THREE.CircleGeometry(DISC_R, 48), discMat);
      disc.userData.index = i;
      group.add(disc);
      discMeshes.push(disc);

      if (post.image) {
        texLoader.load(post.image, (tex) => {
          tex.colorSpace = THREE.SRGBColorSpace;
          coverFit(tex);
          discMat.map = tex;
          discMat.color.set(0xbdbdbd); // slightly dimmed until hover
          discMat.needsUpdate = true;
        });
      }

      const plaque = new THREE.Mesh(
        new THREE.PlaneGeometry(30, 30 * (224 / 1024)),
        new THREE.MeshBasicMaterial({
          map: plaqueTexture(post, CATEGORY_COLORS[post.category] || '#d9a94f'),
          transparent: true,
          depthWrite: false,
        })
      );
      plaque.position.y = -DISC_R - 6.4;
      group.add(plaque);
    });

    /* ---------- The black hole ---------- */
    const holeGroup = new THREE.Group();
    holeGroup.position.set(pathX(zHole), pathY(zHole), zHole);
    scene.add(holeGroup);

    // Accretion disc — tilted, swirling
    const discPlane = new THREE.Mesh(
      new THREE.PlaneGeometry(210, 210),
      new THREE.ShaderMaterial({
        transparent: true,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
        uniforms: { uTime: { value: 0 } },
        vertexShader: `
          varying vec2 vUv;
          void main() {
            vUv = uv;
            gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
          }
        `,
        fragmentShader: `
          uniform float uTime;
          varying vec2 vUv;
          void main() {
            vec2 p = vUv - 0.5;
            float r = length(p) * 2.0;
            float ang = atan(p.y, p.x);
            float swirl = ang + uTime * 0.22 + 2.6 / (r + 0.22);
            float bands = 0.55 + 0.45 * sin(swirl * 5.0 + r * 20.0);
            float disc = smoothstep(1.0, 0.5, r) * smoothstep(0.16, 0.36, r);
            vec3 inner = vec3(1.0, 0.82, 0.45);
            vec3 outer = vec3(0.72, 0.45, 0.95);
            vec3 col = mix(inner, outer, smoothstep(0.25, 0.95, r));
            col = mix(col, vec3(1.0, 0.95, 0.8), bands * 0.3);
            float a = disc * (0.3 + 0.7 * bands);
            gl_FragColor = vec4(col, a);
          }
        `,
      })
    );
    discPlane.rotation.x = -1.25;
    discPlane.rotation.y = 0.18;
    holeGroup.add(discPlane);

    // The hole itself: opaque black core + photon rim, always facing camera
    const core = new THREE.Mesh(
      new THREE.CircleGeometry(15, 64),
      new THREE.MeshBasicMaterial({ color: 0x000000 })
    );
    holeGroup.add(core);

    const rim = new THREE.Mesh(
      new THREE.PlaneGeometry(36, 36),
      new THREE.ShaderMaterial({
        transparent: true,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
        uniforms: { uTime: { value: 0 } },
        vertexShader: `
          varying vec2 vUv;
          void main() {
            vUv = uv;
            gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
          }
        `,
        fragmentShader: `
          uniform float uTime;
          varying vec2 vUv;
          void main() {
            vec2 p = vUv - 0.5;
            float r = length(p) * 2.0;
            float rim = smoothstep(0.09, 0.0, abs(r - 0.86));
            float flicker = 0.85 + 0.15 * sin(uTime * 3.0 + r * 10.0);
            gl_FragColor = vec4(vec3(1.0, 0.85, 0.55) * flicker, rim * 0.9);
          }
        `,
      })
    );
    holeGroup.add(rim);

    // Glow behind everything
    const glowMat = new THREE.SpriteMaterial({
      map: nebulaTexture('#e8b45f'),
      transparent: true,
      opacity: 0.75,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
    });
    const glow = new THREE.Sprite(glowMat);
    glow.scale.set(420, 420, 1);
    glow.position.z = -30;
    holeGroup.add(glow);

    // Stars caught in the pull — a slow spiral
    const SPIRAL_N = 420;
    const spPos = new Float32Array(SPIRAL_N * 3);
    const spSize = new Float32Array(SPIRAL_N);
    const spPhase = new Float32Array(SPIRAL_N);
    const spSpeed = new Float32Array(SPIRAL_N);
    const spRand = hash('the-pull');
    for (let i = 0; i < SPIRAL_N; i++) {
      const t = spRand();
      const arm = spRand() < 0.5 ? 0 : Math.PI;
      const theta = arm + t * 4.6 + spRand() * 0.5;
      const rad = 24 + t * 150;
      spPos[i * 3] = Math.cos(theta) * rad;
      spPos[i * 3 + 1] = Math.sin(theta) * rad * 0.4;
      spPos[i * 3 + 2] = (spRand() - 0.5) * 22;
      spSize[i] = 0.6 + spRand() * 1.6;
      spPhase[i] = spRand();
      spSpeed[i] = 0.5 + spRand() * 1.6;
    }
    const spGeo = new THREE.BufferGeometry();
    spGeo.setAttribute('position', new THREE.BufferAttribute(spPos, 3));
    spGeo.setAttribute('aSize', new THREE.BufferAttribute(spSize, 1));
    spGeo.setAttribute('aPhase', new THREE.BufferAttribute(spPhase, 1));
    spGeo.setAttribute('aSpeed', new THREE.BufferAttribute(spSpeed, 1));
    const spiral = new THREE.Points(spGeo, starMat.clone());
    spiral.rotation.copy(discPlane.rotation);
    holeGroup.add(spiral);

    /* ---------- Camera + interaction state ---------- */
    let progress = 0; // eased
    let mouseX = 0;
    let mouseY = 0;
    let lookX = 0;
    let lookY = 0;
    let hovered = -1;
    let focused = -1;
    let focusT = 0; // 0 = on rail, 1 = at portal
    let running = false;
    let flying = false;
    let hintGone = false;
    let ended = false;

    const railPos = new THREE.Vector3();
    const focusPos = new THREE.Vector3();
    const railQuat = new THREE.Quaternion();
    const focusQuat = new THREE.Quaternion();
    // Must be a camera: Object3D.lookAt points +Z at the target, cameras view down -Z
    const dummy = new THREE.PerspectiveCamera();
    const raycaster = new THREE.Raycaster();
    const pointer = new THREE.Vector2(-10, -10);

    window.addEventListener(
      'pointermove',
      (e) => {
        pointer.x = (e.clientX / innerWidth) * 2 - 1;
        pointer.y = -(e.clientY / innerHeight) * 2 + 1;
        mouseX = pointer.x;
        mouseY = pointer.y;
      },
      { passive: true }
    );

    /* ---------- Audio ---------- */
    let audio: ReturnType<typeof makeAudio> | null = null;
    let muted = false;

    muteBtn.addEventListener('click', () => {
      muted = !muted;
      audio?.setMuted(muted);
      muteBtn.textContent = muted ? 'SOUND OFF' : 'SOUND ON';
    });

    /* ---------- Texture preload, then arm the launch button ---------- */
    const preload = posts
      .filter((p) => p.image)
      .map(
        (p) =>
          new Promise<void>((res) => {
            const img = new Image();
            img.onload = () => res();
            img.onerror = () => res();
            img.src = p.image;
          })
      );

    const dbg: Record<string, boolean> = ((window as any).__saDebug = {
      images: false,
      fonts: false,
      armed: false,
    });

    function armLaunch() {
      dbg.armed = true;
      gateLaunch.disabled = false;
      gateLaunch.textContent = 'Launch';
    }

    const imagesReady = Promise.all(preload).then(() => {
      dbg.images = true;
    });
    const fontsReady = Promise.resolve(
      (document as any).fonts?.ready
    ).then(() => {
      dbg.fonts = true;
    });

    Promise.all([imagesReady, fontsReady]).then(armLaunch);
    // Never strand the visitor on a stuck preload
    setTimeout(() => {
      if (!dbg.armed) armLaunch();
    }, 5000);

    /* ---------- Flight mode on/off ---------- */
    const lenis = () => (window as any).__lenis;

    function enterFlight() {
      flying = true;
      document.body.classList.add('flying');
      flatSection.style.display = 'none';
      track.style.height = `${posts.length * 55 + 280}vh`;
      window.scrollTo(0, 0);
      lenis()?.scrollTo(0, { immediate: true });
      gate.classList.add('leaving');
      setTimeout(() => {
        gate.classList.remove('show', 'leaving');
        gate.setAttribute('aria-hidden', 'true');
      }, 900);
      canvas.classList.add('is-on');
      if (!audio) audio = makeAudio();
      audio.ctx.resume();
      audio.setMuted(muted);
      if (!running) {
        running = true;
        lastT = tNow();
        requestAnimationFrame(frame);
      }
    }

    function exitFlight() {
      flying = false;
      running = false;
      closeFocus(true);
      document.body.classList.remove('flying');
      canvas.classList.remove('is-on');
      flatSection.style.display = '';
      track.style.height = '0';
      endCard.classList.remove('show');
      ended = false;
      audio?.setMuted(true);
      window.scrollTo(0, 0);
      lenis()?.scrollTo(0, { immediate: true });
    }

    gateLaunch.addEventListener('click', enterFlight);
    relaunch.addEventListener('click', enterFlight);
    gateSkip.addEventListener('click', () => {
      gate.classList.add('leaving');
      setTimeout(() => {
        gate.classList.remove('show', 'leaving');
        gate.setAttribute('aria-hidden', 'true');
      }, 900);
    });
    exitBtn.addEventListener('click', exitFlight);
    endFlat.addEventListener('click', exitFlight);
    returnLaunch.addEventListener('click', () => {
      lenis()?.scrollTo(0, { duration: 3 });
    });

    /* ---------- Portal focus ---------- */
    function openFocus(i: number) {
      if (focused === i) return;
      focused = i;
      const post = posts[i];
      focusMeta.textContent = `${tagLabel(post.tag)} ✦ ${post.category}`;
      (focusMeta as HTMLElement).style.color = CATEGORY_COLORS[post.category] || '';
      focusTitle.textContent = post.title;
      focusDate.textContent = post.dateLabel;
      focusDesc.textContent = post.description;
      focusRead.href = `/post/${post.slug}`;
      focusCard.classList.add('show');
      focusCard.setAttribute('aria-hidden', 'false');
      lenis()?.stop();
      gsap.to({ v: focusT }, {
        v: 1,
        duration: 1.4,
        ease: 'power3.inOut',
        onUpdate() {
          focusT = (this.targets()[0] as any).v;
        },
      });
    }

    function closeFocus(instant = false) {
      if (focused === -1) return;
      focused = -1;
      focusCard.classList.remove('show');
      focusCard.setAttribute('aria-hidden', 'true');
      lenis()?.start();
      if (instant) {
        focusT = 0;
        return;
      }
      gsap.to({ v: focusT }, {
        v: 0,
        duration: 1.1,
        ease: 'power3.inOut',
        onUpdate() {
          focusT = (this.targets()[0] as any).v;
        },
      });
    }

    focusClose.addEventListener('click', () => closeFocus());
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeFocus();
    });

    canvas.addEventListener('click', () => {
      if (!flying) return;
      if (focused !== -1) {
        closeFocus();
        return;
      }
      if (hovered >= 0) {
        audio?.chime();
        openFocus(hovered);
      }
    });

    /* ---------- HUD ---------- */
    function updateHud(camZ: number, p: number) {
      hudGaugeFill.style.height = `${Math.round(p * 100)}%`;
      let nearest = -1;
      let best = Infinity;
      for (let i = 0; i < portalPos.length; i++) {
        const d = Math.abs(camZ - portalPos[i].z);
        if (d < best) {
          best = d;
          nearest = i;
        }
      }
      if (nearest >= 0 && best < 220) {
        const post = posts[nearest];
        hudSector.textContent = `TRANSMISSION ${String(nearest + 1).padStart(2, '0')}/${posts.length} · SECTOR ${post.year}`;
      } else if (camZ < zHole + 400) {
        hudSector.textContent = 'APPROACHING EVENT HORIZON';
      } else {
        hudSector.textContent = 'DEEP SPACE';
      }
    }

    /* ---------- Frame loop ---------- */
    const t0 = performance.now();
    const tNow = () => (performance.now() - t0) / 1000;
    let lastT = 0;
    let hudTick = 0;

    function frame() {
      if (!running) return;
      const t = tNow();
      lastT = t;

      // Scroll → progress (Lenis already smooths the scroll itself).
      // Frozen while a portal is in focus so nothing can yank the camera mid-read.
      if (focused === -1) {
        const scrollable = Math.max(1, document.documentElement.scrollHeight - innerHeight);
        const target = Math.min(1, Math.max(0, scrollY / scrollable));
        progress += (target - progress) * 0.07;
      }

      if (!hintGone && scrollY > 60) {
        hintGone = true;
        hudHint.classList.add('gone');
      }

      const camZ = Z_START + (Z_END - Z_START) * progress;

      // Rail pose — mouse-look eased so portals don't dodge the cursor
      lookX += (mouseX - lookX) * 0.06;
      lookY += (mouseY - lookY) * 0.06;
      railPos.set(pathX(camZ), pathY(camZ), camZ);
      const lookAhead = camZ - 90;
      dummy.position.copy(railPos);
      dummy.lookAt(
        pathX(lookAhead) + lookX * 26,
        pathY(lookAhead) + lookY * 16,
        lookAhead
      );
      railQuat.copy(dummy.quaternion);

      // Focus pose (blend toward the focused portal)
      if (focused !== -1 || focusT > 0.001) {
        const i = focused !== -1 ? focused : Math.max(0, hovered);
        const pp = portalPos[Math.min(i, portalPos.length - 1)];
        const back = new THREE.Vector3(pathX(pp.z + 90) - pp.x, 0, 90).normalize();
        focusPos.copy(pp).addScaledVector(back, 42);
        focusPos.y = pp.y + 1;
        // Shift left so the DOM card on the right doesn't cover the portal
        focusPos.x += back.z * 0 - 6;
        dummy.position.copy(focusPos);
        dummy.lookAt(pp);
        focusQuat.copy(dummy.quaternion);
        camera.position.lerpVectors(railPos, focusPos, focusT);
        camera.quaternion.slerpQuaternions(railQuat, focusQuat, focusT);
      } else {
        camera.position.copy(railPos);
        camera.quaternion.copy(railQuat);
      }

      // Uniforms
      starMat.uniforms.uTime.value = t;
      (spiral.material as THREE.ShaderMaterial).uniforms.uTime.value = t;
      (discPlane.material as THREE.ShaderMaterial).uniforms.uTime.value = t;
      (rim.material as THREE.ShaderMaterial).uniforms.uTime.value = t;
      core.quaternion.copy(camera.quaternion);
      rim.quaternion.copy(camera.quaternion);
      spiral.rotation.z = t * 0.05;

      // Hover raycast (only while on the rail)
      let hit = -1;
      if (focused === -1 && focusT < 0.05) {
        raycaster.setFromCamera(pointer, camera);
        const hits = raycaster.intersectObjects(discMeshes, false);
        if (hits.length) hit = hits[0].object.userData.index;
      }
      if (hit !== hovered) {
        hovered = hit;
        document.body.style.cursor = hit >= 0 ? 'pointer' : '';
      }
      ringMats.forEach((m, i) => {
        m.uniforms.uTime.value = t;
        const want = i === hovered || i === focused ? 1 : 0;
        m.uniforms.uBoost.value += (want - m.uniforms.uBoost.value) * 0.1;
      });
      discMeshes.forEach((d, i) => {
        const mat = d.material as THREE.MeshBasicMaterial;
        if (mat.map) {
          const bright = i === hovered || i === focused ? 0xffffff : 0xbdbdbd;
          mat.color.setHex(bright);
        }
      });

      // Proximity chime
      for (let i = 0; i < portalPos.length; i++) {
        const d = Math.abs(camZ - portalPos[i].z);
        if (d < 70 && !chimed[i]) {
          chimed[i] = true;
          audio?.chime();
        } else if (d > 160 && chimed[i]) {
          chimed[i] = false;
        }
      }

      // End card
      if (progress > 0.985 && !ended) {
        ended = true;
        endCard.classList.add('show');
        endCard.setAttribute('aria-hidden', 'false');
      } else if (progress < 0.96 && ended) {
        ended = false;
        endCard.classList.remove('show');
        endCard.setAttribute('aria-hidden', 'true');
      }

      // HUD every few frames
      if (++hudTick % 8 === 0) updateHud(camZ, progress);

      renderer.render(scene, camera);
      requestAnimationFrame(frame);
    }

    /* ---------- Housekeeping ---------- */
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        running = false;
      } else if (flying && !running) {
        running = true;
        lastT = tNow();
        requestAnimationFrame(frame);
      }
    });

    window.addEventListener('resize', () => {
      camera.aspect = innerWidth / innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(innerWidth, innerHeight);
      renderer.setPixelRatio(Math.min(devicePixelRatio, dprCap));
    });

    // Dev introspection hook (harmless in production)
    (window as any).__sa = { scene, camera, renderer, portalPos, discMeshes };
  }

  // Called last so every const above is initialised before init touches it.
  if (eligible) {
    try {
      init();
    } catch (err) {
      // Surface init failures where we can see them (console capture can miss module errors)
      gateLaunch.textContent = 'INIT ERR: ' + (err as Error).message;
      console.error('[space-archive]', err);
    }
  }
</script>
