---
interface CardItem {
  title: string;
  slug: string;
  image?: string;
}

interface Props {
  cards: CardItem[];
}

const { cards } = Astro.props;
const total = cards.length;
---

<div class="fan-container">
  <div class="fan-slider">
    {cards.map((card, i) => (
      <a
        href={`/post/${card.slug}`}
        class="fan-card"
        style={`z-index: ${total - i}`}
      >
        {card.image && <img src={card.image} alt={card.title} />}
        <div class="fan-card-overlay">
          <span class="fan-card-title">{card.title}</span>
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  .fan-container {
    position: relative;
    width: 100%;
    height: 620px;
    overflow: visible;
    perspective: 1400px;
  }

  .fan-slider {
    position: absolute;
    top: 50%;
    left: 42%;
    transform-style: preserve-3d;
    transform:
      translate3d(-50%, -50%, 0)
      rotateX(5deg)
      rotateY(-30deg)
      rotateZ(-117deg);
  }

  .fan-card {
    display: block;
    position: relative;
    width: fit-content;
    height: 350px;
    margin: -190px 0;
    border-radius: 12px;
    overflow: hidden;
    background-color: #1a1a1a;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    transform: rotateX(37deg) rotateY(-4deg) rotateZ(140deg);
    transition:
      transform 0.7s cubic-bezier(0.075, 0.82, 0.165, 1),
      box-shadow 0.7s cubic-bezier(0.075, 0.82, 0.165, 1);
  }

  .fan-card:first-child {
    margin-top: 0;
  }

  .fan-card:last-child {
    margin-bottom: 0;
  }

  .fan-card img {
    width: 620px;
    height: 350px;
    object-fit: cover;
    display: block;
  }

  .fan-card:hover {
    transform: rotateX(37deg) rotateY(-4deg) rotateZ(140deg) translateY(-80px) translateZ(20px);
    box-shadow: 0 40px 80px -12px rgba(0, 0, 0, 0.45);
    z-index: 100 !important;
  }

  .fan-card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 14px 18px;
    padding-bottom: 20px;
    background: linear-gradient(rgba(0, 0, 0, 0.75), transparent);
  }

  .fan-card-title {
    color: #fff;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
  }

  @media (max-width: 768px) {
    .fan-container {
      height: 400px;
    }
    .fan-slider {
      transform:
        translate3d(-50%, -50%, 0)
        rotateX(5deg)
        rotateY(-30deg)
        rotateZ(-117deg)
        scale(0.45);
    }
  }
</style>
