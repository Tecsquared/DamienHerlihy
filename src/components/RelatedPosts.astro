---
import { getCollection } from 'astro:content';
import PostCardGrid from './PostCardGrid.astro';

interface Props {
  currentSlug: string;
  category: string;
}

const { currentSlug, category } = Astro.props;

const allPosts = await getCollection('posts');
const related = allPosts
  .filter((p) => p.id !== currentSlug && p.data.category === category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

{
  related.length > 0 && (
    <section class="related-posts">
      <p class="eyebrow">Same constellation</p>
      <h2 class="related-heading">Nearby stars</h2>
      <div class="related-grid">
        {related.map((post) => (
          <PostCardGrid
            title={post.data.title}
            category={post.data.category}
            date={post.data.date}
            slug={post.id}
            image={post.data.tag.startsWith('Star') ? '/images/menu-star.png' : post.data.image}
          />
        ))}
      </div>
    </section>
  )
}

<style>
  .related-posts {
    margin-top: clamp(60px, 8vw, 100px);
  }

  .related-heading {
    font-size: clamp(26px, 3vw, 38px);
    margin: 16px 0 36px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  @media (max-width: 900px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
