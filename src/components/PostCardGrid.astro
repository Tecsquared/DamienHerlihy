---
import CategoryTag from './CategoryTag.astro';

interface Props {
  title: string;
  category: string;
  date: Date;
  slug: string;
  image?: string;
}

const { title, category, date, slug, image } = Astro.props;

const dateStr = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).toUpperCase();
---

<a href={`/post/${slug}`} class="grid-card">
  <div class="grid-card-image-wrapper">
    <div class="grid-card-image" style={image ? `background-image: url(${image})` : ''}></div>
  </div>
  <div class="grid-card-body">
    <div class="grid-card-meta">
      <CategoryTag category={category} />
      <span class="grid-card-date">{dateStr}</span>
    </div>
    <h3 class="grid-card-title">{title}</h3>
  </div>
</a>

<style>
  .grid-card {
    display: block;
  }

  .grid-card-image-wrapper {
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 16px;
  }

  .grid-card-image {
    aspect-ratio: 4 / 3;
    background-color: #e8e8e8;
    background-size: cover;
    background-position: center;
    transition: transform .3s cubic-bezier(.25, .46, .45, .94);
  }

  .grid-card:hover .grid-card-image {
    transform: scale(1.05);
  }

  .grid-card-body {
    padding: 0;
  }

  .grid-card-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }

  .grid-card-date {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--color-text-light);
  }

  .grid-card-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-black);
    line-height: 1.3;
  }

  .grid-card:hover .grid-card-title {
    text-decoration: underline;
  }
</style>
