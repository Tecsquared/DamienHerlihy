---
interface Props {
  title: string;
  category: string;
  date: Date;
  slug: string;
  image?: string;
}

const { title, category, date, slug, image } = Astro.props;

const dateStr = date
  .toLocaleDateString('en-AU', { year: 'numeric', month: 'short' })
  .toUpperCase();
---

<a href={`/post/${slug}`} class="grid-card spotlight-card">
  <div class="grid-card-frame">
    {
      image ? (
        <img class="grid-card-image" src={image} alt="" loading="lazy" />
      ) : (
        <div class="grid-card-image grid-card-image-empty">
          <span aria-hidden="true">&#10022;</span>
        </div>
      )
    }
  </div>
  <div class="grid-card-body">
    <div class="grid-card-meta">
      <span class="grid-card-cat">{category}</span>
      <span class="grid-card-date">{dateStr}</span>
    </div>
    <h3 class="grid-card-title">{title}</h3>
    <span class="grid-card-go">
      Read
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M4 20 L20 4 M8 4 h12 v12"></path>
      </svg>
    </span>
  </div>
</a>

<style>
  .grid-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--hairline);
    border-radius: var(--r-lg);
    background: rgba(13, 13, 20, 0.62);
    padding: 8px;
    height: 100%;
    transition:
      border-color 0.5s var(--ease),
      transform 0.5s var(--ease);
  }

  .grid-card:hover {
    border-color: var(--gold-dim);
    transform: translateY(-6px);
  }

  .grid-card-frame {
    border-radius: calc(var(--r-lg) - 8px);
    overflow: hidden;
    border: 1px solid var(--hairline);
  }

  .grid-card-image {
    aspect-ratio: 16 / 10;
    width: 100%;
    object-fit: cover;
    filter: saturate(0.9);
    transition:
      transform 0.8s var(--ease),
      filter 0.8s var(--ease);
  }

  .grid-card:hover .grid-card-image {
    transform: scale(1.05);
    filter: saturate(1);
  }

  .grid-card-image-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-raised);
    color: var(--gold);
    font-size: 28px;
  }

  .grid-card-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 22px 16px 16px;
    flex: 1;
  }

  .grid-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .grid-card-cat,
  .grid-card-date {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .grid-card-cat {
    color: var(--gold);
  }

  .grid-card-title {
    font-size: clamp(19px, 1.8vw, 23px);
    line-height: 1.3;
    color: var(--ink);
    transition: color 0.4s var(--ease);
  }

  .grid-card:hover .grid-card-title {
    color: var(--gold-bright);
  }

  .grid-card-go {
    margin-top: auto;
    padding-top: 10px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-faint);
    transition: color 0.4s var(--ease);
  }

  .grid-card-go svg {
    width: 11px;
    height: 11px;
    transition: transform 0.4s var(--ease);
  }

  .grid-card:hover .grid-card-go {
    color: var(--gold);
  }

  .grid-card:hover .grid-card-go svg {
    transform: translate(2px, -2px);
  }
</style>
