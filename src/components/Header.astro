---
interface SearchPost {
  title: string;
  description: string;
  category: string;
  tag: string;
  slug: string;
}

interface Props {
  posts?: SearchPost[];
}

const { posts = [] } = Astro.props;

const navGroups = [
  {
    heading: 'Page',
    links: [
      { label: 'Home', href: '/' },
      { label: 'About', href: '/about' },
      { label: 'Now', href: '/now' },
    ],
  },
  {
    heading: 'Digital Universe',
    links: [
      { label: 'Essays', href: '/essays' },
      { label: 'Notes', href: '/notes' },
      { label: 'Library', href: '/library' },
      { label: 'Archive', href: '/archive' },
    ],
  },
  {
    heading: 'Connect',
    links: [
      { label: 'Contact', href: '/contact' },
      { label: 'Services', href: '/services' },
      { label: 'Newsletter', href: 'https://dis-aster.vercel.app' },
    ],
  },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="header" id="header">
  <div class="header-inner container">
    <a href="/" class="wordmark" aria-label="Damien Herlihy — home">
      <span class="wordmark-bold">Damien.</span><span class="wordmark-light">Herlihy</span><span
        class="caret"></span>
    </a>

    <div class="header-actions">
      <button class="search-trigger" id="search-trigger" aria-label="Open search">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span class="trigger-label">Search</span>
        <span class="kbd">⌘K</span>
      </button>

      <button class="menu-trigger" id="menu-trigger" aria-expanded="false" aria-controls="menu-overlay" aria-label="Open index">
        <span class="trigger-label">Index</span>
        <span class="burger" aria-hidden="true">
          <span class="burger-line"></span>
          <span class="burger-line"></span>
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Full-screen index -->
<div class="menu-overlay" id="menu-overlay" aria-hidden="true">
  <nav class="menu-grid container" aria-label="Site index">
    {
      navGroups.map((group) => (
        <div class="menu-col">
          <span class="menu-heading eyebrow">{group.heading}</span>
          <ul class="menu-list">
            {group.links.map((link) => {
              const isActive = currentPath === link.href;
              return (
                <li class="menu-item">
                  <a
                    href={link.href}
                    class:list={['menu-link', { active: isActive }]}
                    aria-current={isActive ? 'page' : undefined}
                    target={link.href.startsWith('http') ? '_blank' : undefined}
                    rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </nav>
  <div class="menu-footer container">
    <span class="menu-footer-note">A digital universe of notes, essays &amp; ideas</span>
    <div class="menu-footer-links">
      <a href="https://www.youtube.com/@damienherlihy" target="_blank" rel="noopener noreferrer">YouTube</a>
      <a href="https://www.languagelayouts.com/" target="_blank" rel="noopener noreferrer">Language Layouts</a>
      <a href="https://dis-aster.vercel.app" target="_blank" rel="noopener noreferrer">disASTER</a>
    </div>
  </div>
</div>

<!-- Search -->
<div class="search-overlay" id="search-overlay" aria-hidden="true">
  <div class="search-inner container">
    <div class="search-header">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="search-glyph">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input
        type="text"
        class="search-input"
        id="search-input"
        placeholder="Search the universe…"
        autocomplete="off"
        aria-label="Search posts"
      />
      <button class="search-close" id="search-close" aria-label="Close search">
        <span class="kbd">ESC</span>
      </button>
    </div>
    <div class="search-results" id="search-results"></div>
  </div>
</div>

<script type="application/json" id="search-data" set:html={JSON.stringify(posts)} />

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    transition:
      background-color 0.5s var(--ease),
      border-color 0.5s var(--ease),
      backdrop-filter 0.5s var(--ease);
    border-bottom: 1px solid transparent;
  }

  .header.is-scrolled {
    background: rgba(8, 8, 13, 0.72);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom-color: var(--hairline);
  }

  .header-inner {
    height: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .wordmark {
    font-family: var(--font-body);
    font-size: 21px;
    letter-spacing: -0.01em;
    color: var(--ink);
    white-space: nowrap;
  }

  .wordmark-bold {
    font-weight: 600;
  }

  .wordmark-light {
    font-weight: 300;
    color: var(--ink-dim);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .search-trigger,
  .menu-trigger {
    display: flex;
    align-items: center;
    gap: 10px;
    background: none;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 10px 16px;
    cursor: pointer;
    color: var(--ink-dim);
    transition:
      color 0.4s var(--ease),
      border-color 0.4s var(--ease),
      background-color 0.4s var(--ease);
  }

  .search-trigger:hover,
  .menu-trigger:hover {
    color: var(--ink);
    border-color: var(--hairline-strong);
    background: rgba(236, 234, 227, 0.04);
  }

  .trigger-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .kbd {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
    border: 1px solid var(--hairline);
    border-radius: 5px;
    padding: 2px 6px;
  }

  .burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 20px;
    height: 16px;
    position: relative;
  }

  .burger-line {
    display: block;
    height: 1.5px;
    width: 100%;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.45s var(--ease);
    transform-origin: center;
  }

  body.menu-open .burger-line:nth-child(1) {
    transform: translateY(3.25px) rotate(45deg);
  }

  body.menu-open .burger-line:nth-child(2) {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  /* ===== Index overlay ===== */
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-menu);
    background: rgba(5, 5, 8, 0.82);
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    opacity: 0;
    visibility: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition:
      opacity 0.55s var(--ease),
      visibility 0.55s var(--ease);
  }

  .menu-overlay.open {
    opacity: 1;
    visibility: visible;
  }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(32px, 5vw, 80px);
    width: 100%;
  }

  .menu-heading {
    margin-bottom: 22px;
    display: inline-flex;
  }

  .menu-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .menu-item {
    overflow: hidden;
  }

  .menu-link {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(30px, 3.6vw, 48px);
    line-height: 1.25;
    color: var(--ink);
    transition:
      color 0.4s var(--ease),
      font-style 0.4s var(--ease),
      transform 0.5s var(--ease);
    transform: translateY(110%);
  }

  .menu-overlay.open .menu-link {
    transform: translateY(0);
  }

  .menu-link:hover {
    color: var(--gold-bright);
    font-style: italic;
  }

  .menu-link.active {
    color: var(--gold);
  }

  .menu-link.active::after {
    content: '\2726';
    font-size: 0.4em;
    vertical-align: super;
    margin-left: 10px;
    color: var(--gold-dim);
  }

  .menu-footer {
    position: absolute;
    bottom: 36px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    opacity: 0;
    transition: opacity 0.6s var(--ease) 0.35s;
  }

  .menu-overlay.open .menu-footer {
    opacity: 1;
  }

  .menu-footer-note {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .menu-footer-links {
    display: flex;
    gap: 24px;
  }

  .menu-footer-links a {
    font-size: 14px;
    color: var(--ink-dim);
    transition: color 0.3s var(--ease);
  }

  .menu-footer-links a:hover {
    color: var(--gold-bright);
  }

  /* ===== Search overlay ===== */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-search);
    background: rgba(5, 5, 8, 0.86);
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.4s var(--ease),
      visibility 0.4s var(--ease);
  }

  .search-overlay.open {
    opacity: 1;
    visibility: visible;
  }

  .search-inner {
    padding-top: clamp(90px, 16vh, 160px);
    max-width: 760px;
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 18px;
    border-bottom: 1px solid var(--hairline-strong);
    padding-bottom: 18px;
    margin-bottom: 12px;
  }

  .search-glyph {
    color: var(--gold);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    font-family: var(--font-display);
    font-size: clamp(24px, 3.4vw, 38px);
    font-weight: 400;
    color: var(--ink);
    background: none;
    border: none;
    outline: none;
    min-width: 0;
  }

  .search-input::placeholder {
    color: var(--ink-faint);
  }

  .search-close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--ink-dim);
    padding: 4px;
  }

  .search-close:hover .kbd {
    color: var(--ink);
    border-color: var(--hairline-strong);
  }

  .search-results {
    display: flex;
    flex-direction: column;
    max-height: 60vh;
    overflow-y: auto;
    scrollbar-width: thin;
  }

  @media (max-width: 768px) {
    .wordmark {
      font-size: 18px;
    }

    .trigger-label,
    .kbd {
      display: none;
    }

    .search-trigger,
    .menu-trigger {
      padding: 10px;
      color: var(--ink);
    }

    .menu-trigger .trigger-label {
      display: none;
    }

    .menu-grid {
      grid-template-columns: 1fr;
      gap: 26px;
      padding-top: 70px;
      overflow-y: auto;
      max-height: calc(100dvh - 150px);
    }

    .menu-link {
      font-size: 28px;
    }

    .menu-heading {
      margin-bottom: 10px;
    }

    .menu-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
      bottom: 22px;
    }
  }
</style>

<script>
  const header = document.getElementById('header')!;
  const menuTrigger = document.getElementById('menu-trigger')!;
  const menuOverlay = document.getElementById('menu-overlay')!;
  const searchTrigger = document.getElementById('search-trigger')!;
  const searchOverlay = document.getElementById('search-overlay')!;
  const searchInput = document.getElementById('search-input')! as HTMLInputElement;
  const searchClose = document.getElementById('search-close')!;
  const searchResults = document.getElementById('search-results')!;

  const posts: { title: string; description: string; category: string; tag: string; slug: string }[] =
    JSON.parse(document.getElementById('search-data')!.textContent || '[]');

  function lockScroll(lock: boolean) {
    const lenis = (window as any).__lenis;
    if (lenis) (lock ? lenis.stop() : lenis.start());
    document.body.style.overflow = lock ? 'hidden' : '';
  }

  /* ---- Index menu ---- */
  const menuLinks = menuOverlay.querySelectorAll<HTMLElement>('.menu-link');
  menuLinks.forEach((link, i) => {
    link.style.transitionDelay = `${0.08 + i * 0.045}s`;
  });

  function setMenu(open: boolean) {
    document.body.classList.toggle('menu-open', open);
    menuOverlay.classList.toggle('open', open);
    menuOverlay.setAttribute('aria-hidden', String(!open));
    menuTrigger.setAttribute('aria-expanded', String(open));
    menuTrigger.setAttribute('aria-label', open ? 'Close index' : 'Open index');
    if (!open) menuLinks.forEach((l) => (l.style.transitionDelay = '0s'));
    else menuLinks.forEach((l, i) => (l.style.transitionDelay = `${0.08 + i * 0.045}s`));
    lockScroll(open);
  }

  menuTrigger.addEventListener('click', () => setMenu(!document.body.classList.contains('menu-open')));

  /* ---- Search ---- */
  function openSearch() {
    setMenu(false);
    searchOverlay.classList.add('open');
    searchOverlay.setAttribute('aria-hidden', 'false');
    searchInput.value = '';
    renderResults('');
    lockScroll(true);
    setTimeout(() => searchInput.focus(), 60);
  }

  function closeSearch() {
    searchOverlay.classList.remove('open');
    searchOverlay.setAttribute('aria-hidden', 'true');
    lockScroll(false);
  }

  function renderResults(query: string) {
    const q = query.toLowerCase().trim();
    const filtered = q
      ? posts.filter(
          (p) =>
            p.title.toLowerCase().includes(q) ||
            p.description.toLowerCase().includes(q) ||
            p.category.toLowerCase().includes(q)
        )
      : posts;

    searchResults.innerHTML = filtered
      .map(
        (p, i) => `
        <a href="/post/${p.slug}" class="search-result" style="animation-delay:${i * 0.03}s">
          <span class="search-result-title">${p.title}</span>
          <span class="search-result-meta">
            <span class="search-result-pill">${p.tag}</span>
            <span class="search-result-pill">${p.category}</span>
          </span>
        </a>`
      )
      .join('');

    if (q && filtered.length === 0) {
      searchResults.innerHTML =
        '<p class="search-empty">Nothing in this part of the sky. Try another word.</p>';
    }
  }

  searchTrigger.addEventListener('click', openSearch);
  searchClose.addEventListener('click', closeSearch);
  searchInput.addEventListener('input', () => renderResults(searchInput.value));

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      searchOverlay.classList.contains('open') ? closeSearch() : openSearch();
    }
    if (e.key === 'Escape') {
      if (searchOverlay.classList.contains('open')) closeSearch();
      else if (document.body.classList.contains('menu-open')) setMenu(false);
    }
  });

  /* ---- Glass header on scroll ---- */
  let scrolled = false;
  window.addEventListener(
    'scroll',
    () => {
      const next = window.scrollY > 30;
      if (next !== scrolled) {
        scrolled = next;
        header.classList.toggle('is-scrolled', scrolled);
        document.body.classList.toggle('has-scrolled', scrolled);
      }
    },
    { passive: true }
  );
</script>

<style is:global>
  @keyframes result-in {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .search-result {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 18px 4px;
    border-bottom: 1px solid var(--hairline);
    color: var(--ink);
    opacity: 0;
    animation: result-in 0.5s var(--ease-out) forwards;
    transition: padding-left 0.35s var(--ease);
  }

  .search-result:hover {
    padding-left: 14px;
  }

  .search-result-title {
    font-size: 17px;
    font-weight: 400;
  }

  .search-result:hover .search-result-title {
    color: var(--gold-bright);
  }

  .search-result-meta {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .search-result-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid var(--hairline);
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .search-empty {
    color: var(--ink-faint);
    font-size: 16px;
    padding: 24px 4px;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .search-result {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }

  body.has-scrolled .caret {
    opacity: 0;
    animation: none;
    transition: opacity 0.3s;
  }
</style>
