---
import CategoryTag from './CategoryTag.astro';

interface Props {
  title: string;
  category: string;
  date: Date;
  slug: string;
  image?: string;
}

const { title, category, date, slug, image } = Astro.props;

const dateStr = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).toUpperCase();
---

<a href={`/post/${slug}`} class="featured-card">
  <div class="featured-image" style={image ? `background-image: url(${image})` : ''}>
    <div class="featured-overlay">
      <div class="featured-meta">
        <CategoryTag category={category} variant="dark" />
        <span class="featured-date">{dateStr}</span>
      </div>
      <h3 class="featured-title">{title}</h3>
    </div>
  </div>
</a>

<style>
  /* Entrance animation */
  @keyframes featured-fade-up {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .featured-card {
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    position: relative;
    transition: transform .25s cubic-bezier(.25, .46, .45, .94),
                filter .35s cubic-bezier(.25, .46, .45, .94),
                box-shadow .35s cubic-bezier(.25, .46, .45, .94);
    /* Start hidden, animate when scrolled into view */
    opacity: 0;
    animation: featured-fade-up .6s cubic-bezier(.25, .46, .45, .94) forwards;
    animation-play-state: paused;
  }

  .featured-card.in-view {
    animation-play-state: running;
  }

  /* Staggered delays */
  :global(.featured-grid) .featured-card:nth-child(1) { animation-delay: 0s; }
  :global(.featured-grid) .featured-card:nth-child(2) { animation-delay: .15s; }
  :global(.featured-grid) .featured-card:nth-child(3) { animation-delay: .3s; }

  /* Hover: lift + brighten + shadow */
  .featured-card:hover {
    transform: translateY(-4px);
    filter: brightness(110%);
    box-shadow: 0 30px 50px -15px rgba(0, 0, 0, 0.6);
  }

  .featured-image {
    aspect-ratio: 3 / 4;
    background-color: #1a1a1a;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: flex-end;
  }

  .featured-overlay {
    width: 100%;
    padding: 24px;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
    padding-top: 80px;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .featured-date {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    color: rgba(255, 255, 255, 0.8);
  }

  .featured-title {
    color: #ffffff;
    font-size: 24px;
    font-weight: 700;
    line-height: 1.3;
  }

  .featured-card:hover .featured-title {
    text-decoration: underline;
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-card {
      opacity: 1;
      animation: none;
    }
  }
</style>

<script>
  // Trigger entrance animation when cards scroll into view
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in-view');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.05, rootMargin: '0px 0px 50px 0px' });

  document.querySelectorAll('.featured-card').forEach((card) => {
    // If already visible on page load, trigger immediately
    const rect = card.getBoundingClientRect();
    if (rect.top < window.innerHeight && rect.bottom > 0) {
      card.classList.add('in-view');
    } else {
      observer.observe(card);
    }
  });
</script>
