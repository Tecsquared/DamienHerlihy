---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import PostCardList from '../../components/PostCardList.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection } from 'astro:content';

const categories = [
  { name: 'AI & Teaching', slug: 'ai-and-teaching' },
  { name: 'Personal Knowledge Mgt', slug: 'personal-knowledge-mgt' },
  { name: 'Second Mountain', slug: 'second-mountain' },
  { name: 'Learning How to Learn', slug: 'learning-how-to-learn' },
  { name: 'Languages', slug: 'languages' },
];

export function getStaticPaths() {
  return [
    { params: { slug: 'ai-and-teaching' } },
    { params: { slug: 'personal-knowledge-mgt' } },
    { params: { slug: 'second-mountain' } },
    { params: { slug: 'learning-how-to-learn' } },
    { params: { slug: 'languages' } },
  ];
}

const { slug } = Astro.params;
const category = categories.find((c) => c.slug === slug)!;

const posts = (await getCollection('posts'))
  .filter((p) => p.data.category === category.name)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title={`${category.name} — Damien Herlihy`}
  description={`Every post in the ${category.name} constellation.`}
>
  <section class="container page-content">
    <PageHero eyebrow={`Constellation · ${posts.length} ${posts.length === 1 ? 'star' : 'stars'}`}>
      {category.name}
    </PageHero>

    <div class="category-layout">
      <div class="category-posts">
        {
          posts.map((post, i) => (
            <div data-reveal data-reveal-delay={String(Math.min(i * 0.06, 0.3))}>
              <PostCardList
                title={post.data.title}
                category={post.data.category}
                date={post.data.date}
                slug={post.id}
                image={post.data.image}
              />
            </div>
          ))
        }
        {
          posts.length === 0 && (
            <div class="no-posts">
              <span class="no-posts-glyph" aria-hidden="true">&#10022;</span>
              <p>This patch of sky is still dark — no stars here yet.</p>
              <a href="/notes" class="btn-ghost">Browse the notes instead</a>
            </div>
          )
        }
      </div>

      <Sidebar activeCategory={category.name} />
    </div>
  </section>
</BaseLayout>

<style>
  .category-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: clamp(40px, 6vw, 80px);
  }

  .category-posts > div:first-child :global(.list-row) {
    border-top: 1px solid var(--hairline);
  }

  .no-posts {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
    padding: 40px 0;
    color: var(--ink-faint);
  }

  .no-posts-glyph {
    color: var(--gold);
    font-size: 22px;
  }

  @media (max-width: 900px) {
    .category-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
