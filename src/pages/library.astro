---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PostCardGrid from '../components/PostCardGrid.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter((p) => p.data.tag === 'Library')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Library — Damien Herlihy"
  description="The Library: books, articles, and blogs that lit the way — sources behind this digital universe."
>
  <section class="container page-content">
    <PageHero
      eyebrow={`Library · ${posts.length} lights`}
      description="Books, articles, and blogs that gave me insight — credit where the light came from."
    >
      Where the light <em>came from</em>
    </PageHero>

    <div class="post-grid">
      {
        posts.map((post, i) => (
          <div data-reveal data-reveal-delay={String((i % 3) * 0.08)}>
            <PostCardGrid
              title={post.data.title}
              category={post.data.category}
              date={post.data.date}
              slug={post.id}
              image={post.data.image}
            />
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  @media (max-width: 1024px) {
    .post-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 700px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
