---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCardSmall from '../components/PostCardSmall.astro';
import PostCardList from '../components/PostCardList.astro';
import Sidebar from '../components/Sidebar.astro';
import Subscribe from '../components/Subscribe.astro';
import CardFan from '../components/CardFan.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const featuredPosts = allPosts.filter((p) => p.data.featured).slice(0, 3);
const recentPosts = allPosts.slice(0, 3);
---

<BaseLayout
  title="Damien Herlihy is both a teacher and learner of languages"
  description="Teacher, PKM Nerd, and Video Maker - when the stars align."
>
  <!-- Hero -->
  <section class="hero container">
    <h1 class="hero-title">
      <strong>Damien</strong> is both a teacher and a learner of languages.
    </h1>
    <h6 class="hero-subtitle">
      Teacher, PKM Nerd, and Video Maker - when the stars align.
    </h6>
    <p class="hero-role">
      Right now, I'm the Director of Studies at
      <a
        href="https://www.facebook.com/tectratenglish"
        target="_blank"
        rel="noopener noreferrer">Trat English Community</a
      >.
    </p>
  </section>

  <!-- The Universe -->
  <section class="universe container">
    <h2 class="universe-heading">The Universe</h2>
    <p class="universe-description">
      With notes, essays, and ideas, I am gradually constructing a thematic
      digital universe of knowledge. These reflections are ever-evolving over
      time. This project is a pushback against the shit storm of inauthenticity
      that is crashing against the shores of the Internet.
    </p>
    <p class="universe-description">
      I based this idea on the
      <a href="https://maggieappleton.com/nontechnical-gardening" target="_blank" rel="noopener noreferrer">'Digital Garden'</a> movement.
    </p>
  </section>

  <!-- State of Play Card Fan -->
  {featuredPosts.length > 0 && (
    <div class="card-fan-band">
      <section class="card-fan-section container">
        <h3 class="section-label">Galaxy (Essay)</h3>
        <CardFan cards={featuredPosts.map((p) => ({
          title: p.data.title,
          slug: p.id,
          image: p.data.image,
        }))} />
      </section>
    </div>
  )}

  <!-- Scrolling Thumbnails Row -->
  <section class="scroll-row container">
    <h3 class="section-label">Star (Note)</h3>
    <div class="scroll-row-inner">
      {allPosts.slice(0, 6).map((post) => (
        <PostCardSmall
          title={post.data.title}
          category={post.data.category}
          slug={post.id}
          image={post.data.image}
        />
      ))}
    </div>
  </section>

  <!-- Blog List + Sidebar -->
  <section class="blog-section container">
    <div class="blog-list">
      {recentPosts.map((post) => (
        <div class="post-list-item" data-category={post.data.category}>
          <PostCardList
            title={post.data.title}
            category={post.data.category}
            date={post.data.date}
            slug={post.id}
            image={post.data.image}
          />
        </div>
      ))}

      <div class="see-all">
        <a href="/essays" class="btn-primary">See All Posts</a>
      </div>
    </div>

    <Sidebar />
  </section>

  <!-- Subscribe -->
  <div class="container">
    <Subscribe />
  </div>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding-top: calc(var(--nav-height) + 40px);
    padding-bottom: 20px;
  }

  .hero-title {
    font-size: 50px;
    max-width: 800px;
    margin-bottom: 20px;
  }

  .hero-subtitle {
    color: var(--color-text);
    font-weight: 500;
    margin-bottom: 12px;
  }

  .hero-role {
    color: var(--color-text);
  }

  /* Universe */
  .universe {
    padding: 40px var(--content-padding) 48px;
  }

  .universe-heading {
    font-size: 48px;
    margin-bottom: 20px;
  }

  .universe-description {
    max-width: 900px;
    margin-bottom: 1em;
  }

  /* Section Labels */
  .section-label {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-text-light);
    margin-bottom: 16px;
  }

  /* Card Fan */
  .card-fan-band {
    background-color: #f5f5f5;
    padding: 20px 0;
    margin-bottom: 0;
  }

  .card-fan-section {
    text-align: center;
  }

  /* Scroll Row */
  .scroll-row {
    margin-top: 40px;
    margin-bottom: 48px;
    overflow: hidden;
  }

  .scroll-row-inner {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    padding: 16px 0;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .scroll-row-inner::-webkit-scrollbar {
    display: none;
  }

  /* Blog Section */
  .blog-section {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 60px;
    margin-bottom: 40px;
  }

  .see-all {
    margin-top: 32px;
    max-width: 500px;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 36px;
    }

    .universe-heading {
      font-size: 36px;
    }

    .blog-section {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
