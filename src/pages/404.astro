---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Lost in space — Damien Herlihy"
  description="This page drifted out of the charted universe."
>
  <section class="lost container">
    <div class="lost-stars" aria-hidden="true">
      <span class="ls" style="left: 12%; top: 18%"></span>
      <span class="ls" style="left: 30%; top: 64%; animation-delay: 0.7s"></span>
      <span class="ls" style="left: 48%; top: 26%; animation-delay: 1.4s"></span>
      <span class="ls" style="left: 67%; top: 58%; animation-delay: 0.3s"></span>
      <span class="ls" style="left: 84%; top: 22%; animation-delay: 1.9s"></span>
    </div>

    <p class="eyebrow">Signal lost</p>
    <h1 class="lost-code">4<span class="lost-star" aria-hidden="true">&#10022;</span>4</h1>
    <p class="lede lost-lede">
      This page has drifted out of the charted universe. It may have collapsed, been
      renamed, or never existed at all.
    </p>
    <div class="lost-actions">
      <a href="/" class="btn" data-magnetic>
        Back to the sky
        <span class="btn-orb">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M2 14 L14 2 M5 2 h9 v9"></path>
          </svg>
        </span>
      </a>
      <a href="/notes" class="btn-ghost" data-magnetic>Browse the notes</a>
    </div>
  </section>
</BaseLayout>

<style>
  .lost {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 26px;
    position: relative;
  }

  .lost-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .ls {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--gold);
    opacity: 0.3;
    animation: ls-twinkle 3.2s ease-in-out infinite;
  }

  @keyframes ls-twinkle {
    0%,
    100% {
      opacity: 0.12;
      transform: scale(0.8);
    }
    50% {
      opacity: 0.6;
      transform: scale(1.3);
    }
  }

  .lost-code {
    font-size: clamp(90px, 18vw, 220px);
    line-height: 1;
  }

  .lost-star {
    display: inline-block;
    color: var(--gold);
    font-size: 0.55em;
    vertical-align: 0.1em;
    margin: 0 0.06em;
    animation: lost-spin 9s linear infinite;
  }

  @keyframes lost-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .lost-lede {
    max-width: 44ch;
  }

  .lost-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 8px;
  }
</style>
