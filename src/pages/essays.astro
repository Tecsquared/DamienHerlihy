---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PostCardGrid from '../components/PostCardGrid.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter((p) => p.data.tag === 'Galaxy (Essay)')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Essays — Damien Herlihy"
  description="Galaxies: longform essays where notes are organised into constellations and whole regions of sky."
>
  <section class="container page-content">
    <PageHero
      eyebrow={`Galaxies · ${posts.length} charted`}
      description="Longform pieces where I organise my stars [notes] into constellations [patterns] and galaxies [essays]."
    >
      Whole regions <em>of sky</em>
    </PageHero>

    <div class="post-grid">
      {
        posts.map((post, i) => (
          <div data-reveal data-reveal-delay={String((i % 2) * 0.1)}>
            <PostCardGrid
              title={post.data.title}
              category={post.data.category}
              date={post.data.date}
              slug={post.id}
              image={post.data.image}
            />
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .post-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
  }

  @media (min-width: 769px) {
    .post-grid > div:nth-child(even) {
      margin-top: 40px;
    }
  }

  @media (max-width: 768px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
