---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  // The three most recent Star (Note) posts carry the menu-star emblem in the header.
  const recentStarSlugs = new Set(
    posts
      .filter((p) => p.data.tag.startsWith('Star'))
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
      .slice(0, 3)
      .map((p) => p.id),
  );

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, showStarEmblem: recentStarSlugs.has(post.id) },
  }));
}

const { post, showStarEmblem } = Astro.props;
const { Content } = await render(post);

const dateStr = post.data.date
  .toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' })
  .toUpperCase();

const categorySlugs: Record<string, string> = {
  'AI & Teaching': 'ai-and-teaching',
  'Personal Knowledge Mgt': 'personal-knowledge-mgt',
  'Second Mountain': 'second-mountain',
  'Learning How to Learn': 'learning-how-to-learn',
  Languages: 'languages',
};

function tagLabel(tag: string) {
  if (tag.startsWith('Galaxy')) return 'Galaxy · Essay';
  if (tag.startsWith('Star')) return 'Star · Note';
  if (tag.startsWith('Constellation')) return 'Constellation · Pattern';
  return 'Library';
}

const SITE = Astro.site ?? new URL('https://www.damienherlihy.com');
const postUrl = new URL(Astro.url.pathname, SITE).href;
const postSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  ...(post.data.description ? { description: post.data.description } : {}),
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  ...(post.data.image ? { image: new URL(post.data.image, SITE).href } : {}),
  url: postUrl,
  mainEntityOfPage: postUrl,
  author: { '@id': new URL('/#damien', SITE).href },
  publisher: { '@id': new URL('/#damien', SITE).href },
  isPartOf: { '@id': new URL('/#website', SITE).href },
  articleSection: post.data.category,
  keywords: post.data.tag,
  inLanguage: 'en',
};
---

<BaseLayout
  title={`${post.data.title} — Damien Herlihy`}
  description={post.data.description}
  image={post.data.image}
  schema={postSchema}
>
  <div class="read-progress" aria-hidden="true">
    <span class="read-progress-bar" id="read-progress-bar"></span>
  </div>

  <article class="post-page container page-content">
    <div class="post-header">
      <a href="/" class="post-back" data-reveal>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M19 12 H5 M12 19 L5 12 L12 5"></path>
        </svg>
        Back to the universe
      </a>

      {
        showStarEmblem && (
          <figure class="post-emblem" data-reveal aria-hidden="true">
            <img src="/images/menu-star.png" alt="" width="88" height="88" loading="eager" />
          </figure>
        )
      }

      <div class="post-meta" data-reveal data-reveal-delay="0.06">
        <span class="post-pill post-pill-gold">{tagLabel(post.data.tag)}</span>
        <a class="post-pill" href={`/category/${categorySlugs[post.data.category]}`}>
          {post.data.category}
        </a>
        <span class="post-date">{dateStr}</span>
      </div>

      <h1 class="post-title" data-reveal data-reveal-delay="0.12">{post.data.title}</h1>

      {
        post.data.description && (
          <p class="lede post-lede" data-reveal data-reveal-delay="0.18">
            {post.data.description}
          </p>
        )
      }
    </div>

    {
      post.data.image && (
        <figure class="post-figure" data-reveal>
          <img src={post.data.image} alt="" loading="eager" />
        </figure>
      )
    }

    <div class="prose post-body">
      <Content />
    </div>

    <hr />

    <RelatedPosts currentSlug={post.id} category={post.data.category} />
  </article>
</BaseLayout>

<style>
  .read-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    z-index: calc(var(--z-nav) + 1);
    background: transparent;
    pointer-events: none;
  }

  .read-progress-bar {
    display: block;
    height: 100%;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
  }

  .post-page {
    max-width: 880px;
  }

  .post-header {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: clamp(36px, 5vw, 56px);
  }

  .post-back {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-faint);
    transition: color 0.35s var(--ease);
    width: fit-content;
  }

  .post-back:hover {
    color: var(--gold-bright);
  }

  .post-back svg {
    transition: transform 0.35s var(--ease);
  }

  .post-back:hover svg {
    transform: translateX(-4px);
  }

  .post-emblem {
    margin: 0;
    width: 88px;
    height: 88px;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--hairline);
    background: var(--bg-deep);
    box-shadow: 0 12px 40px -18px rgba(217, 169, 79, 0.5);
  }

  .post-emblem img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .post-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    color: var(--ink-dim);
    transition:
      color 0.35s var(--ease),
      border-color 0.35s var(--ease);
  }

  a.post-pill:hover {
    color: var(--gold-bright);
    border-color: var(--gold-dim);
  }

  .post-pill-gold {
    color: var(--gold);
    border-color: var(--gold-dim);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--ink-faint);
  }

  .post-title {
    font-size: clamp(36px, 5.4vw, 64px);
    max-width: 18ch;
  }

  .post-lede {
    color: var(--ink-dim);
    border-left: 2px solid var(--gold);
    padding-left: 22px;
  }

  .post-figure {
    margin-bottom: clamp(40px, 5vw, 60px);
    border: 1px solid var(--hairline);
    border-radius: var(--r-lg);
    padding: 8px;
    background: rgba(13, 13, 20, 0.62);
  }

  .post-figure img {
    width: 100%;
    border-radius: calc(var(--r-lg) - 8px);
  }

  .post-body {
    margin: 0 auto;
  }

  @media (min-width: 900px) {
    .post-body {
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const bar = document.getElementById('read-progress-bar')!;
  ScrollTrigger.create({
    trigger: '.post-body',
    start: 'top 60%',
    end: 'bottom 40%',
    onUpdate: (self) => {
      bar.style.transform = `scaleX(${self.progress})`;
    },
  });
</script>
